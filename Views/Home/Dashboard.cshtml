@using System.Linq
@using LLB.Helpers
@using LLB.Models.ViewModel

@{
    Layout = "_LayoutMain";
    ViewData["Title"] = "Client Dashboard";
    ViewData["Subtitle"] = "Track applications, approved licences, and every post-formation listing from one workspace";

    var activeTab = ViewBag.ActiveDashboardTab as string ?? "in-progress-pane";
    var renewalListings = ViewBag.RenewalTasks as IEnumerable<RenewalViewModel> ?? Enumerable.Empty<RenewalViewModel>();
    var inspectionListings = ViewBag.Inspections as IEnumerable<InspectionViewModel> ?? Enumerable.Empty<InspectionViewModel>();
    var managerChangeListings = ViewBag.ManagerChangeListings as IEnumerable<ClientPostFormationListingViewModel> ?? Enumerable.Empty<ClientPostFormationListingViewModel>();
    var extendedHourListings = ViewBag.ExtendedHourListings as IEnumerable<ClientPostFormationListingViewModel> ?? Enumerable.Empty<ClientPostFormationListingViewModel>();
    var temporaryRetailListings = ViewBag.TemporaryRetailListings as IEnumerable<ClientPostFormationListingViewModel> ?? Enumerable.Empty<ClientPostFormationListingViewModel>();
    var extraCounterListings = ViewBag.ExtraCounterListings as IEnumerable<ClientPostFormationListingViewModel> ?? Enumerable.Empty<ClientPostFormationListingViewModel>();

    Func<string?, string> statusClass = status => status?.ToLowerInvariant() switch
    {
        "approved" => "llb-status-success",
        "submitted" => "llb-status-info",
        "awaiting approval" => "llb-status-info",
        "payment verification" => "llb-status-info",
        "verified" => "llb-status-success",
        "inprogress" => "llb-status-warning",
        "has query" => "llb-status-warning",
        "rejected" => "llb-status-danger",
        "inspected" => "llb-status-success",
        _ => "llb-status-info"
    };

    Func<string, string> tabButtonClass = tabId => activeTab == tabId ? "nav-link active" : "nav-link";
    Func<string, string> tabPaneClass = tabId => activeTab == tabId ? "tab-pane fade show active" : "tab-pane fade";
    Func<ClientPostFormationListingViewModel, bool> isExtraCounter = listing =>
        listing.Reference?.StartsWith("PF-EXC-", StringComparison.OrdinalIgnoreCase) == true;
    Func<ClientPostFormationListingViewModel, string> displayExtraCounterStatus = listing =>
        isExtraCounter(listing) && string.Equals(listing.Status, "submitted", StringComparison.OrdinalIgnoreCase)
            ? "Initialised"
            : listing.Status ?? "Unknown";
    Func<InspectionViewModel, bool> isDirectInspection = inspection =>
        string.Equals(inspection.Service, "Inspection", StringComparison.OrdinalIgnoreCase);
    Func<InspectionViewModel, bool> inspectionPassed = inspection =>
        string.Equals(inspection.Overall, "true", StringComparison.OrdinalIgnoreCase);
    Func<InspectionViewModel, bool> inspectionFailed = inspection =>
        string.Equals(inspection.Overall, "false", StringComparison.OrdinalIgnoreCase);
    Func<InspectionViewModel, string> inspectionOutcomeText = inspection =>
        inspectionPassed(inspection) ? "Passed" : inspectionFailed(inspection) ? "Failed" : "Pending";
    Func<InspectionViewModel, string> inspectionOutcomeClass = inspection =>
        inspectionPassed(inspection) ? "llb-status-success" : inspectionFailed(inspection) ? "llb-status-danger" : "llb-status-info";
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">In Progress</p>
                    <h3>@ViewBag.Applications.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-folder2-open"></i></span>
            </div>
            <p>Applications that still need submission, payment, review, or query resolution.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Approved Licences</p>
                    <h3>@ViewBag.ApprovedApplications.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-patch-check"></i></span>
            </div>
            <p>Licences already approved and available for download or follow-up services.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Renewals</p>
                    <h3>@ViewBag.RenewalTasks.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-arrow-repeat"></i></span>
            </div>
            <p>Renewal processes linked to your existing licence records.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Inspections</p>
                    <h3>@ViewBag.Inspections.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-clipboard2-pulse"></i></span>
            </div>
            <p>Inspection outcomes and post-inspection records linked to your applications.</p>
        </div>
    </div>
</div>

<div class="card llb-panel-card mb-4">
    <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
        <div>
            <div class="llb-section-kicker">Workspace</div>
            <h2 class="h3 fw-bold mb-2">Manage everything from one dashboard</h2>
            <p class="text-muted mb-0">
                Continue drafts, review approved licences, and launch post-formation services without leaving this workspace.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/License/Apply" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Apply For Licence
            </a>
            <a href="/Home/FAQ" class="btn btn-outline-primary">
                <i class="bi bi-question-circle me-2"></i>View FAQ
            </a>
        </div>
    </div>
</div>

<div class="card llb-table-card">
    <div class="card-body">
        <ul class="nav nav-pills llb-tabs mb-4" id="dashboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="@tabButtonClass("in-progress-pane")" id="in-progress-tab" data-bs-toggle="tab" data-bs-target="#in-progress-pane" type="button" role="tab" aria-selected="@(activeTab == "in-progress-pane")">
                    In Progress
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="@tabButtonClass("licences-pane")" id="licences-tab" data-bs-toggle="tab" data-bs-target="#licences-pane" type="button" role="tab" aria-selected="@(activeTab == "licences-pane")">
                    My Licences
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="@tabButtonClass("services-pane")" id="services-tab" data-bs-toggle="tab" data-bs-target="#services-pane" type="button" role="tab" aria-selected="@(activeTab == "services-pane")">
                    Post Formations
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="@tabPaneClass("in-progress-pane")" id="in-progress-pane" role="tabpanel">
                @if (ViewBag.Applications.Count == 0)
                {
                    <div class="llb-empty-state">
                        <i class="bi bi-folder2-open"></i>
                        <h5 class="fw-bold">No active applications</h5>
                        <p class="text-muted mb-3">Start a new licence application when you are ready.</p>
                        <a href="/License/Apply" class="btn btn-primary">Apply For Licence</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>Trading Name</th>
                                    <th>Licence</th>
                                    <th>For</th>
                                    <th>Applied</th>
                                    <th>Status</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var application in ViewBag.Applications)
                                {
                                    <tr>
                                        <td class="fw-semibold">@application.RefNum</td>
                                        <td>
                                            @foreach (var outlet in ViewBag.OutletInfo)
                                            {
                                                if (outlet.ApplicationId == application.Id)
                                                {
                                                    @outlet.TradingName
                                                }
                                            }
                                        </td>
                                        <td>
                                            @foreach (var licence in ViewBag.License)
                                            {
                                                if (licence.Id == application.LicenseTypeID)
                                                {
                                                    @licence.LicenseName
                                                }
                                            }
                                        </td>
                                        <td>
                                            @foreach (var region in ViewBag.Regions)
                                            {
                                                if (region.Id == application.ApplicationType)
                                                {
                                                    @region.RegionName
                                                }
                                            }
                                        </td>
                                        <td>@application.ApplicationDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="llb-status-pill @statusClass(application.Status)">@application.Status</span>
                                        </td>
                                        <td class="text-end">
                                            @if (application.Status == "inprogress" || application.Status == "Has Query")
                                            {
                                                <a href="/License/Apply?Id=@application.Id" class="btn btn-sm btn-primary">Continue</a>
                                            }
                                            else
                                            {
                                                if (AgentLicenseHelper.IsAgentLicenseApplication(application))
                                                {
                                                    <a href="/AgentLicense/Apply?id=@application.Id" class="btn btn-sm btn-outline-primary">View</a>
                                                }
                                                else
                                                {
                                                    <a href="~/Viewing/Apply?Id=@application.Id" class="btn btn-sm btn-outline-primary">View</a>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="@tabPaneClass("licences-pane")" id="licences-pane" role="tabpanel">
                @if (ViewBag.ApprovedApplications.Count == 0)
                {
                    <div class="llb-empty-state">
                        <i class="bi bi-patch-check"></i>
                        <h5 class="fw-bold">No approved licences yet</h5>
                        <p class="text-muted mb-0">Approved licences will appear here once processing is complete.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>LLB Number</th>
                                    <th>Trading Name</th>
                                    <th>Expiry Date</th>
                                    <th>Licence</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var application in ViewBag.ApprovedApplications)
                                {
                                    <tr>
                                        <td class="fw-semibold">@application.RefNum</td>
                                        <td>@application.LLBNum</td>
                                        <td>
                                            @foreach (var outlet in ViewBag.OutletInfo)
                                            {
                                                if (outlet.ApplicationId == application.Id)
                                                {
                                                    @outlet.TradingName
                                                }
                                            }
                                        </td>
                                        <td>@application.ExpiryDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @foreach (var licence in ViewBag.License)
                                            {
                                                if (licence.Id == application.LicenseTypeID)
                                                {
                                                    @licence.LicenseName
                                                }
                                            }
                                        </td>
                                        <td>
                                            <span class="llb-status-pill @statusClass(application.Status)">@application.Status</span>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end flex-wrap gap-2">
                                                <a href="/Downloads/CheckDownload?LLBNUM=@application.LLBNum&DocumentType=License" class="btn btn-sm btn-primary">
                                                    Download / Duplicate
                                                </a>
                                                @foreach (var outlet in ViewBag.OutletInfo)
                                                {
                                                    if (outlet.ApplicationId == application.Id)
                                                    {
                                                        var renewalStartDate = application.ExpiryDate.AddMonths(-1);
                                                        var isRenewalEligible = DateTime.Now.Date >= renewalStartDate.Date;
                                                        var renewalWarning = isRenewalEligible
                                                            ? ""
                                                            : $"Renewal can only start within one month of expiry. This licence expires on {application.ExpiryDate:dd MMMM yyyy}, so renewal opens on {renewalStartDate:dd MMMM yyyy}.";

                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-primary"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#PostFormationModal"
                                                                data-application-id="@application.Id"
                                                                data-trading-name="@outlet.TradingName"
                                                                data-renewal-eligible="@isRenewalEligible.ToString().ToLowerInvariant()"
                                                                data-renewal-warning="@renewalWarning">
                                                            Post Formation
                                                        </button>
                                                    }
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="@tabPaneClass("services-pane")" id="services-pane" role="tabpanel">
                <div class="row g-4">
                    <div class="col-12">
                        <div class="card llb-panel-card" id="renewal-listings">
                            <div class="card-header">
                                <h5 class="card-title">Renewal Applications</h5>
                            </div>
                            <div class="card-body">
                                @if (!renewalListings.Any())
                                {
                                    <div class="llb-empty-state">
                                        <i class="bi bi-arrow-repeat"></i>
                                        <h5 class="fw-bold">No renewal records</h5>
                                        <p class="text-muted mb-0">Renewal requests linked to your licences will appear here.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Trading Name</th>
                                                    <th>LLB Number</th>
                                                    <th>Expiry Date</th>
                                                    <th>Licence</th>
                                                    <th>For</th>
                                                    <th>Status</th>
                                                    <th class="text-end">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var renewal in renewalListings)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@(!string.IsNullOrWhiteSpace(renewal.Reference) ? renewal.Reference : "N/A")</td>
                                                        <td class="fw-semibold">@renewal.TradingName</td>
                                                        <td>@renewal.LLBNumber</td>
                                                        <td>@(renewal.PreviousExpiry?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                                        <td>@renewal.Licensetype</td>
                                                        <td>@renewal.LicenseRegion</td>
                                                        <td>
                                                            <span class="llb-status-pill @statusClass(renewal.Status)">@renewal.Status</span>
                                                        </td>
                                                        <td class="text-end">
                                                            <a class="btn btn-sm btn-outline-primary" href="/Postprocess/Renewal?id=@renewal.ApplicationId&process=RNW&renid=@renewal.Id">View Renewal</a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card llb-panel-card" id="inspection-listings">
                            <div class="card-header">
                                <h5 class="card-title">Inspections</h5>
                            </div>
                            <div class="card-body">
                                @if (!inspectionListings.Any())
                                {
                                    <div class="llb-empty-state">
                                        <i class="bi bi-clipboard2-pulse"></i>
                                        <h5 class="fw-bold">No inspection records</h5>
                                        <p class="text-muted mb-0">Completed inspections associated with your applications will appear here.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Trading Name</th>
                                                    <th>LLB Number</th>
                                                    <th>Inspection Date</th>
                                                    <th>Licence</th>
                                                    <th>For</th>
                                                    <th>Service</th>
                                                    <th>Status</th>
                                                    <th>Outcome</th>
                                                    <th class="text-end">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var inspection in inspectionListings)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@(!string.IsNullOrWhiteSpace(inspection.Reference) ? inspection.Reference : "N/A")</td>
                                                        <td class="fw-semibold">@inspection.TradingName</td>
                                                        <td>@inspection.LLBNumber</td>
                                                        <td>@inspection.InspectionDate.ToString("dd MMM yyyy")</td>
                                                        <td>@inspection.LicenseType</td>
                                                        <td>@inspection.LicenseRegion</td>
                                                        <td>@inspection.Service</td>
                                                        <td>
                                                            <span class="llb-status-pill @statusClass(inspection.Status)">@inspection.Status</span>
                                                        </td>
                                                        <td>
                                                            <span class="llb-status-pill @inspectionOutcomeClass(inspection)">@inspectionOutcomeText(inspection)</span>
                                                        </td>
                                                        <td class="text-end">
                                                            @if (isDirectInspection(inspection) && inspectionPassed(inspection))
                                                            {
                                                                <a class="btn btn-sm btn-outline-primary" href="/Documents/InspectionComplianceCertificate?searchref=@inspection.Id">View Certificate</a>
                                                            }
                                                            else if (isDirectInspection(inspection) && inspectionFailed(inspection))
                                                            {
                                                                <a class="btn btn-sm btn-outline-danger" href="/Documents/InspectionFailedReport?searchref=@inspection.Id">View Failed Report</a>
                                                                <a class="btn btn-sm btn-primary ms-1" href="/Postprocess/Inspection?id=@inspection.ApplicationId&process=INP">Resubmit</a>
                                                            }
                                                            else
                                                            {
                                                                <a class="btn btn-sm btn-outline-primary" href="/Viewing/inspection?Id=@inspection.Id">View Inspection</a>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card llb-panel-card" id="manager-change-listings">
                            <div class="card-header">
                                <h5 class="card-title">Manager Change Listings</h5>
                            </div>
                            <div class="card-body">
                                @if (!managerChangeListings.Any())
                                {
                                    <div class="llb-empty-state">
                                        <i class="bi bi-person-badge"></i>
                                        <h5 class="fw-bold">No manager change records</h5>
                                        <p class="text-muted mb-0">Manager change submissions will appear here after you start one from an approved licence.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Trading Name</th>
                                                    <th>LLB Number</th>
                                                    <th>Submitted</th>
                                                    <th>Licence</th>
                                                    <th>For</th>
                                                    <th>Status</th>
                                                    <th class="text-end">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var listing in managerChangeListings)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@listing.Reference</td>
                                                        <td class="fw-semibold">@listing.TradingName</td>
                                                        <td>@listing.LLBNumber</td>
                                                        <td>@(listing.SubmittedDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                                        <td>@listing.LicenseName</td>
                                                        <td>@listing.RegionName</td>
                                                        <td>
                                                            <span class="llb-status-pill @statusClass(listing.Status)">@listing.Status</span>
                                                        </td>
                                                        <td class="text-end">
                                                            <a class="btn btn-sm btn-outline-primary" href="@listing.ActionUrl">@listing.ActionLabel</a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card llb-panel-card" id="extended-hours-listings">
                            <div class="card-header">
                                <h5 class="card-title">Extended Hours Listings</h5>
                            </div>
                            <div class="card-body">
                                @if (!extendedHourListings.Any())
                                {
                                    <div class="llb-empty-state">
                                        <i class="bi bi-clock-history"></i>
                                        <h5 class="fw-bold">No extended hours records</h5>
                                        <p class="text-muted mb-0">Extended hours requests will appear here after you submit one from an approved licence.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Trading Name</th>
                                                    <th>LLB Number</th>
                                                    <th>Extended Hours Date</th>
                                                    <th>Submitted</th>
                                                    <th>Licence</th>
                                                    <th>For</th>
                                                    <th>Status</th>
                                                    <th class="text-end">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var listing in extendedHourListings)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@listing.Reference</td>
                                                        <td class="fw-semibold">@listing.TradingName</td>
                                                        <td>@listing.LLBNumber</td>
                                                        <td>@(listing.EventDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                                        <td>@(listing.SubmittedDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                                        <td>@listing.LicenseName</td>
                                                        <td>@listing.RegionName</td>
                                                        <td>
                                                            <span class="llb-status-pill @statusClass(listing.Status)">@listing.Status</span>
                                                        </td>
                                                        <td class="text-end">
                                                            <a class="btn btn-sm btn-outline-primary" href="@listing.ActionUrl">@listing.ActionLabel</a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card llb-panel-card" id="temporary-retail-listings">
                            <div class="card-header">
                                <h5 class="card-title">Temporary Retail Listings</h5>
                            </div>
                            <div class="card-body">
                                @if (!temporaryRetailListings.Any())
                                {
                                    <div class="llb-empty-state">
                                        <i class="bi bi-shop-window"></i>
                                        <h5 class="fw-bold">No temporary retail records</h5>
                                        <p class="text-muted mb-0">Temporary retail requests will appear here after you submit one from an approved licence.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Trading Name</th>
                                                    <th>LLB Number</th>
                                                    <th>Submitted</th>
                                                    <th>Licence</th>
                                                    <th>For</th>
                                                    <th>Status</th>
                                                    <th class="text-end">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var listing in temporaryRetailListings)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@listing.Reference</td>
                                                        <td class="fw-semibold">@listing.TradingName</td>
                                                        <td>@listing.LLBNumber</td>
                                                        <td>@(listing.SubmittedDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                                        <td>@listing.LicenseName</td>
                                                        <td>@listing.RegionName</td>
                                                        <td>
                                                            <span class="llb-status-pill @statusClass(listing.Status)">@listing.Status</span>
                                                        </td>
                                                        <td class="text-end">
                                                            <a class="btn btn-sm btn-outline-primary" href="@listing.ActionUrl">@listing.ActionLabel</a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card llb-panel-card" id="extra-counter-listings">
                            <div class="card-header">
                                <h5 class="card-title">Permission To Alter / Extra Counter Listings</h5>
                            </div>
                            <div class="card-body">
                                @if (!extraCounterListings.Any())
                                {
                                    <div class="llb-empty-state">
                                        <i class="bi bi-layout-text-window"></i>
                                        <h5 class="fw-bold">No permission to alter or extra counter records</h5>
                                        <p class="text-muted mb-0">Permission to alter and extra counter applications will appear here after you start one from an approved licence.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Trading Name</th>
                                                    <th>LLB Number</th>
                                                    <th>Submitted / Initialised</th>
                                                    <th>Licence</th>
                                                    <th>For</th>
                                                    <th>Status</th>
                                                    <th class="text-end">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var listing in extraCounterListings)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@listing.Reference</td>
                                                        <td class="fw-semibold">@listing.TradingName</td>
                                                        <td>@listing.LLBNumber</td>
                                                        <td>@(listing.SubmittedDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                                        <td>@listing.LicenseName</td>
                                                        <td>@listing.RegionName</td>
                                                        <td>
                                                            <span class="llb-status-pill @statusClass(listing.Status)">@displayExtraCounterStatus(listing)</span>
                                                        </td>
                                                        <td class="text-end">
                                                            <a class="btn btn-sm btn-outline-primary" href="@listing.ActionUrl">@listing.ActionLabel</a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="PostFormationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title">Post Formation Service</h5>
                    <p class="text-muted mb-0">Select the next service for <span class="fw-semibold text-dark" id="feetitle"></span>.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/Home/PostFormation" method="post">
                <div class="modal-body pt-3">
                    <input type="hidden" name="id" id="ApplicationId" />
                    <label for="process" class="llb-form-section-label">Service</label>
                    <select class="form-select llb-modal-select" name="process" id="process" required>
                        <option value="">Choose a service</option>
                        <option value="RNW">Renewal</option>
                        <option value="APM">Change or approval of a manager</option>
                        <option value="INP">Inspection</option>
                        <option value="TRM">Temporary removal</option>
                        <option value="TTR">Transfer</option>
                        <option value="EXH">Extended hours liquor licence</option>
                        <option value="TRL">Temporary retail liquor licence</option>
                        <option value="ECF">Permission to alter</option>
                        <option value="EXC">Extra counter</option>
                    </select>
                    <div class="alert alert-warning d-none mt-3 mb-0" id="renewalEligibilityWarning" role="alert"></div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Proceed</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const modalElement = document.getElementById("PostFormationModal");
        const processElement = document.getElementById("process");
        const renewalWarningElement = document.getElementById("renewalEligibilityWarning");
        if (!modalElement) {
            return;
        }

        const syncRenewalOption = function () {
            if (!processElement || !renewalWarningElement) {
                return;
            }

            const renewalOption = processElement.querySelector('option[value="RNW"]');
            const isRenewalEligible = modalElement.dataset.renewalEligible === "true";
            const renewalWarning = modalElement.dataset.renewalWarning || "";

            if (renewalOption) {
                renewalOption.disabled = !isRenewalEligible;
            }

            if (!isRenewalEligible && renewalWarning) {
                if (processElement.value === "RNW") {
                    processElement.value = "";
                }

                renewalWarningElement.textContent = renewalWarning;
                renewalWarningElement.classList.remove("d-none");
            } else {
                renewalWarningElement.textContent = "";
                renewalWarningElement.classList.add("d-none");
            }
        };

        modalElement.addEventListener("show.bs.modal", function (event) {
            const trigger = event.relatedTarget;
            if (!trigger) {
                return;
            }

            document.getElementById("ApplicationId").value = trigger.getAttribute("data-application-id") || "";
            document.getElementById("feetitle").textContent = trigger.getAttribute("data-trading-name") || "";
            document.getElementById("process").value = "";
            modalElement.dataset.renewalEligible = trigger.getAttribute("data-renewal-eligible") || "false";
            modalElement.dataset.renewalWarning = trigger.getAttribute("data-renewal-warning") || "";
            syncRenewalOption();
        });

        if (processElement) {
            processElement.addEventListener("change", syncRenewalOption);
        }
    });
</script>
