@using System.Linq
@using LLB.Models.ViewModel

@{
    Layout = "_LayoutMain";
    ViewData["Title"] = "Renewal Listings";
    var renewalListings = ViewBag.RenewalTasks as IEnumerable<RenewalViewModel> ?? Enumerable.Empty<RenewalViewModel>();

    Func<string?, string> statusClass = status => status?.ToLowerInvariant() switch
    {
        "approved" => "llb-status-success",
        "submitted" => "llb-status-info",
        "payment verification" => "llb-status-info",
        "verified" => "llb-status-success",
        "inprogress" => "llb-status-warning",
        "has query" => "llb-status-warning",
        "rejected" => "llb-status-danger",
        "inspected" => "llb-status-success",
        _ => "llb-status-info"
    };
}

<div class="card llb-panel-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h5 class="card-title mb-1">Renewal Listings</h5>
            <p class="text-muted mb-0">All renewal requests linked to your licences.</p>
        </div>
        <a class="btn btn-outline-primary" href="/Home/Dashboard?tab=services-pane">Back To Dashboard</a>
    </div>
    <div class="card-body">
        @if (!renewalListings.Any())
        {
            <div class="llb-empty-state">
                <i class="bi bi-arrow-repeat"></i>
                <h5 class="fw-bold">No renewal records</h5>
                <p class="text-muted mb-0">Renewal requests linked to your licences will appear here.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Trading Name</th>
                            <th>LLB Number</th>
                            <th>Expiry Date</th>
                            <th>Licence</th>
                            <th>For</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var renewal in renewalListings)
                        {
                            <tr>
                                <td class="fw-semibold">@(!string.IsNullOrWhiteSpace(renewal.Reference) ? renewal.Reference : "N/A")</td>
                                <td class="fw-semibold">@renewal.TradingName</td>
                                <td>@renewal.LLBNumber</td>
                                <td>@(renewal.PreviousExpiry?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                <td>@renewal.Licensetype</td>
                                <td>@renewal.LicenseRegion</td>
                                <td>
                                    <span class="llb-status-pill @statusClass(renewal.Status)">@renewal.Status</span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="/Postprocess/Renewal?id=@renewal.ApplicationId&process=RNW&renid=@renewal.Id">View Renewal</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
