@using System.Linq
@using LLB.Models.ViewModel

@{
    Layout = "_LayoutMain";
    ViewData["Title"] = "Permission To Alter / Extra Counter Listings";
    var listings = ViewBag.ExtraCounterListings as IEnumerable<ClientPostFormationListingViewModel> ?? Enumerable.Empty<ClientPostFormationListingViewModel>();

    Func<string?, string> statusClass = status => status?.ToLowerInvariant() switch
    {
        "approved" => "llb-status-success",
        "submitted" => "llb-status-info",
        "awaiting approval" => "llb-status-info",
        "payment verification" => "llb-status-info",
        "verified" => "llb-status-success",
        "inprogress" => "llb-status-warning",
        "has query" => "llb-status-warning",
        "rejected" => "llb-status-danger",
        "inspected" => "llb-status-success",
        _ => "llb-status-info"
    };

    Func<ClientPostFormationListingViewModel, bool> isExtraCounter = listing =>
        listing.Reference?.StartsWith("PF-EXC-", StringComparison.OrdinalIgnoreCase) == true;
    Func<ClientPostFormationListingViewModel, string> displayStatus = listing =>
        isExtraCounter(listing) && string.Equals(listing.Status, "submitted", StringComparison.OrdinalIgnoreCase)
            ? "Initialised"
            : listing.Status ?? "Unknown";
}

<div class="card llb-panel-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h5 class="card-title mb-1">Permission To Alter / Extra Counter Listings</h5>
            <p class="text-muted mb-0">Permission to alter and extra counter applications linked to your licences.</p>
        </div>
        <a class="btn btn-outline-primary" href="/Home/Dashboard?tab=services-pane">Back To Dashboard</a>
    </div>
    <div class="card-body">
        @if (!listings.Any())
        {
            <div class="llb-empty-state">
                <i class="bi bi-layout-text-window"></i>
                <h5 class="fw-bold">No permission to alter or extra counter records</h5>
                <p class="text-muted mb-0">Permission to alter and extra counter applications will appear here after you start one from an approved licence.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Trading Name</th>
                            <th>LLB Number</th>
                            <th>Submitted / Initialised</th>
                            <th>Licence</th>
                            <th>For</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var listing in listings)
                        {
                            <tr>
                                <td class="fw-semibold">@listing.Reference</td>
                                <td class="fw-semibold">@listing.TradingName</td>
                                <td>@listing.LLBNumber</td>
                                <td>@(listing.SubmittedDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                <td>@listing.LicenseName</td>
                                <td>@listing.RegionName</td>
                                <td>
                                    <span class="llb-status-pill @statusClass(listing.Status)">@displayStatus(listing)</span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="@listing.ActionUrl">@listing.ActionLabel</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
