@{
    Layout = "_Layout";
    ViewData["Title"] = "Portal Overview";
}

<section id="hero" class="llb-hero">
    <div class="container-xxl">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <span class="llb-chip mb-3">
                    <i class="bi bi-shield-check"></i>
                    National digital licensing service
                </span>
                <h1 class="llb-section-heading mb-3">
                    Apply, renew, track, and manage liquor licences from one portal.
                </h1>
                <p class="llb-section-copy mb-4">
                    The LLB platform gives applicants and internal teams one structured workflow for licensing, inspections, post-formation services, payments, and certificate access.
                </p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <a href="/Auth/Register" class="btn btn-primary btn-lg">Start a new application</a>
                    <a href="/Auth/Login" class="btn btn-outline-primary btn-lg">Sign in to continue</a>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card llb-metric-card">
                            <h3>24/7</h3>
                            <p>Access applications and post-approval services online.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card llb-metric-card">
                            <h3>1 Portal</h3>
                            <p>Registration, licensing, renewals, inspections, and downloads.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card llb-metric-card">
                            <h3>Live Status</h3>
                            <p>Track progress through verification, recommendation, and approval.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card llb-hero-card">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <img src="@Url.Content("~/front/img/IMG/Coat_of_arms_of_ZimbabweB.png")" alt="LLB Coat of Arms" class="img-fluid" style="max-width: 88px;" />
                        <div>
                            <div class="llb-chip mb-2">Liquor Licensing Board</div>
                            <h3 class="h4 mb-0 text-white">Digital Means for Liquor Enterprising</h3>
                        </div>
                    </div>

                    <ul class="llb-soft-list">
                        <li>
                            <i class="bi bi-check2-circle"></i>
                            <div>
                                <strong class="d-block text-white">Structured application flow</strong>
                                Capture applicant details, outlet information, supporting documents, and payment steps.
                            </div>
                        </li>
                        <li>
                            <i class="bi bi-check2-circle"></i>
                            <div>
                                <strong class="d-block text-white">Clear internal workflow</strong>
                                Route work through verifier, recommender, secretary, inspector, and accountant roles.
                            </div>
                        </li>
                        <li>
                            <i class="bi bi-check2-circle"></i>
                            <div>
                                <strong class="d-block text-white">Post-formation services</strong>
                                Handle renewals, inspections, manager changes, temporary removals, extended hours, and duplications.
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="py-5">
    <div class="container-xxl">
        <div class="text-center mb-5">
            <div class="llb-section-kicker">Why This Portal</div>
            <h2 class="fw-bold">A cleaner licensing process for applicants and internal teams</h2>
            <p class="llb-section-copy mb-0">
                The system centralizes submissions, approvals, payment tracking, and document access into one operational workspace.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card llb-feature-card">
                    <div class="llb-stat-icon mb-3"><i class="bi bi-ui-checks-grid"></i></div>
                    <h4 class="fw-bold">Faster submissions</h4>
                    <p>Applicants can complete the full licensing journey online without relying on disconnected paperwork.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card llb-feature-card">
                    <div class="llb-stat-icon mb-3"><i class="bi bi-arrow-repeat"></i></div>
                    <h4 class="fw-bold">Transparent progress</h4>
                    <p>Application states, renewals, inspections, and approved licences are visible from a single dashboard.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card llb-feature-card">
                    <div class="llb-stat-icon mb-3"><i class="bi bi-file-earmark-lock"></i></div>
                    <h4 class="fw-bold">Digital record keeping</h4>
                    <p>Certificates, supporting documents, and payment references stay attached to the licensing record.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="services" class="py-5">
    <div class="container-xxl">
        <div class="text-center mb-5">
            <div class="llb-section-kicker">Services</div>
            <h2 class="fw-bold">Core licensing and compliance services</h2>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-xl-4">
                <div class="card llb-service-card">
                    <h4 class="fw-bold">New licence applications</h4>
                    <p>Capture applicant, outlet, manager, and attachment details for fresh licence requests.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="card llb-service-card">
                    <h4 class="fw-bold">Renewals</h4>
                    <p>Renew existing licences with previous licence references, expiry dates, and follow-up inspections.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="card llb-service-card">
                    <h4 class="fw-bold">Inspections</h4>
                    <p>Record inspection schedules, inspection status, and direct inspection services linked to applications.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="card llb-service-card">
                    <h4 class="fw-bold">Manager changes</h4>
                    <p>Manage approval or change of a person serving as the responsible licence manager.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="card llb-service-card">
                    <h4 class="fw-bold">Temporary and extended services</h4>
                    <p>Handle temporary retail licences, temporary transfers, removals, extended hours, and permission to alter requests.</p>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="card llb-service-card">
                    <h4 class="fw-bold">Licence downloads and duplicates</h4>
                    <p>Access approved licence documents and duplicate certificates through the portal.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container-xxl">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card llb-auth-card">
                    <div class="llb-section-kicker">How It Works</div>
                    <h3 class="fw-bold mb-3">One process, from submission to certificate</h3>
                    <ul class="llb-soft-list">
                        <li>
                            <i class="bi bi-1-circle"></i>
                            <div>Create an account and start a licence or renewal application.</div>
                        </li>
                        <li>
                            <i class="bi bi-2-circle"></i>
                            <div>Upload supporting documents and complete payment steps where required.</div>
                        </li>
                        <li>
                            <i class="bi bi-3-circle"></i>
                            <div>Internal teams verify, inspect, recommend, approve, and clear payments.</div>
                        </li>
                        <li>
                            <i class="bi bi-4-circle"></i>
                            <div>Applicants track progress and download approved licences or related documents.</div>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-6" id="contact">
                <div class="card llb-auth-card">
                    <div class="llb-section-kicker">Ready To Use The Portal</div>
                    <h3 class="fw-bold mb-3">Move licensing work out of paper queues</h3>
                    <p class="llb-section-copy mb-4">
                        Register to submit a new application or sign in to continue an in-progress request, check an approved licence, or start a post-formation service.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="/Auth/Register" class="btn btn-primary">Register</a>
                        <a href="/Auth/Login" class="btn btn-outline-primary">Sign In</a>
                        <a href="/Home/FAQ" class="btn btn-light border">View FAQ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
