@{
    Layout = "_Layout";
    ViewData["Title"] = "Frequently Asked Questions";
}

<section class="llb-page-hero">
    <div class="container-xxl">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="card llb-faq-card mb-4">
                    <div class="card-body p-4 p-lg-5">
                        <div class="llb-section-kicker">Support</div>
                        <h1 class="fw-bold mb-2">Frequently Asked Questions</h1>
                        <p class="text-muted mb-4">
                            Search the knowledge base below for common questions on registration, applications, renewals, payments, and licence management.
                        </p>
                        <input type="text" id="searchInput" class="form-control" placeholder="Search FAQs..." onkeyup="filterFAQs()" />
                    </div>
                </div>

                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqOne">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">
                                What is this portal for?
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                This portal is the digital service point for liquor licensing in Zimbabwe. It supports new applications, renewals, inspections, duplicate licence requests, manager changes, and other post-formation services.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqTwo">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">
                                Who can use the portal?
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Applicants, businesses, and organizations that need to apply for or manage a liquor licence can use the portal. Internal LLB staff also use it for review, verification, inspections, approvals, and payment handling.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqThree">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree">
                                Is there a fee to create an account?
                            </button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Registration is free. Standard liquor licensing and service fees still apply to applications, renewals, transfers, inspections, and other transactions.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqFour">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour">
                                What can I do after signing in?
                            </button>
                        </h2>
                        <div id="collapseFour" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                You can continue draft applications, track submitted requests, view approved licences, download documents, and initiate post-formation services such as renewals, inspections, extended hours, and temporary retail requests.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqFive">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFive">
                                What documents do I need for an application?
                            </button>
                        </h2>
                        <div id="collapseFive" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                The required documents depend on the service you are applying for. The portal captures applicant information, outlet details, attachments, and payment information as part of the workflow.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqSix">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSix">
                                Can I renew a licence through the portal?
                            </button>
                        </h2>
                        <div id="collapseSix" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Yes. The portal supports renewals linked to your previous licence details, expiry dates, inspection status, and related payment steps.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqSeven">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSeven">
                                What payment methods are handled in the system?
                            </button>
                        </h2>
                        <div id="collapseSeven" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                The application includes payment handling and Paynow transaction flows for licence and post-formation services. Payment verification is then handled by internal accounting users.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqEight">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEight">
                                How do I get an approved licence document?
                            </button>
                        </h2>
                        <div id="collapseEight" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Once your application is approved, the client dashboard provides access to download the generated licence document directly from the portal.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqNine">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseNine">
                                Can I request manager changes or temporary services?
                            </button>
                        </h2>
                        <div id="collapseNine" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Yes. The system supports manager change processes, temporary removals, temporary transfers, extra counter requests, temporary retail services, and extended hours applications.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item faq-item">
                        <h2 class="accordion-header" id="faqTen">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTen">
                                Where do I go if I still need help?
                            </button>
                        </h2>
                        <div id="collapseTen" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Start with the portal dashboard and status screens. If you still need help, use the board contact details shown on the site footer and follow your internal process for support escalation.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function filterFAQs() {
        const searchText = document.getElementById("searchInput").value.toLowerCase();
        const faqItems = document.querySelectorAll(".faq-item");

        faqItems.forEach(item => {
            const text = item.textContent.toLowerCase();
            item.style.display = text.includes(searchText) ? "" : "none";
        });
    }
</script>
