@{
    Layout = "_Layout";
    ViewData["Title"] = "Sign In";
}

<section class="llb-page-hero">
    <div class="container-xxl">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="row g-4 align-items-stretch">
                    <div class="col-lg-5">
                        <div class="card llb-hero-card h-100">
                            <div class="llb-section-kicker text-white-50">Applicant Access</div>
                            <h1 class="h2 fw-bold text-white mb-3">Continue your licensing work.</h1>
                            <p class="mb-4">
                                Sign in to view in-progress applications, download approved licences, and submit post-formation services.
                            </p>
                            <img class="img-fluid rounded-4 mb-4" src="@Url.Content("~/front/img/IMG/Coat_of_arms_of_ZimbabweB.png")" alt="LLB" style="max-width: 220px;" />
                            <ul class="llb-soft-list">
                                <li>
                                    <i class="bi bi-check2-circle"></i>
                                    <div>Track verification, recommendation, and approval progress.</div>
                                </li>
                                <li>
                                    <i class="bi bi-check2-circle"></i>
                                    <div>Access renewals, inspections, and licence downloads from one dashboard.</div>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="card llb-auth-card h-100">
                            <div class="card-body p-4 p-lg-5">
                                <div class="llb-section-kicker">Sign In</div>
                                <h2 class="fw-bold mb-2">Welcome back</h2>
                                <p class="text-muted mb-4">Use your registered email address and password to access the portal.</p>

                                @if (TempData["error"] != null)
                                {
                                    <div class="alert alert-danger border-0 rounded-4 mb-4">@TempData["error"]</div>
                                }

                                <form action="/Auth/Login" method="post" enctype="multipart/form-data">
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <span class="llb-form-section-label">Email Address</span>
                                            <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required />
                                        </div>
                                        <div class="col-12">
                                            <span class="llb-form-section-label">Password</span>
                                            <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password" required />
                                        </div>
                                        <div class="col-12 d-grid mt-2">
                                            <button class="btn btn-primary btn-lg" type="submit">Sign In</button>
                                        </div>
                                    </div>
                                </form>

                                <div class="d-flex flex-wrap justify-content-between gap-3 mt-4 pt-3 border-top">
                                    <a href="/Auth/Register" class="text-decoration-none fw-semibold">Create a new account</a>
                                    <a href="/Home/FAQ" class="text-decoration-none fw-semibold">Need help using the portal?</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
