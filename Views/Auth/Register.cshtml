@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Account";
}

<section class="llb-page-hero">
    <div class="container-xxl">
        <div class="row justify-content-center">
            <div class="col-xl-11">
                <div class="row g-4 align-items-start">
                    <div class="col-lg-4">
                        <div class="card llb-hero-card h-100">
                            <div class="llb-section-kicker text-white-50">Create Account</div>
                            <h1 class="h2 fw-bold text-white mb-3">Register once and manage the full licence lifecycle online.</h1>
                            <p class="mb-4">
                                Your account gives you access to applications, renewals, approved licences, inspections, and post-formation services.
                            </p>

                            <ul class="llb-soft-list mb-4">
                                <li>
                                    <i class="bi bi-person-badge"></i>
                                    <div>Capture applicant and contact details in one secure profile.</div>
                                </li>
                                <li>
                                    <i class="bi bi-globe2"></i>
                                    <div>Select nationality, residence country, and province from standardized lists.</div>
                                </li>
                                <li>
                                    <i class="bi bi-file-earmark-check"></i>
                                    <div>Use the same account for applications, renewals, and licence downloads.</div>
                                </li>
                            </ul>

                            <div class="llb-split-card">
                                <h5 class="text-white fw-bold mb-2">Before you start</h5>
                                <p class="mb-0">Keep your email, phone number, physical address, and ID or passport details ready for registration.</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="card llb-auth-card">
                            <div class="card-body p-4 p-lg-5">
                                <div class="llb-section-kicker">Applicant Registration</div>
                                <h2 class="fw-bold mb-2">Create your LLB portal account</h2>
                                <p class="text-muted mb-4">Complete the form below to register for digital liquor licensing services.</p>

                                @if (TempData["success"] != null)
                                {
                                    <div class="alert alert-success border-0 rounded-4 mb-4">@TempData["success"]</div>
                                }

                                @if (TempData["error"] != null)
                                {
                                    <div class="alert alert-danger border-0 rounded-4 mb-4">@TempData["error"]</div>
                                }

                                <form action="/Auth/Register" method="post" enctype="multipart/form-data">
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <span class="llb-form-section-label">Personal Details</span>
                                        </div>

                                        <div class="col-md-6">
                                            <input type="text" class="form-control" id="name" name="name" placeholder="First name" required />
                                        </div>
                                        <div class="col-md-6">
                                            <input type="text" class="form-control" id="lastName" name="lastName" placeholder="Surname" required />
                                        </div>
                                        <div class="col-md-6">
                                            <input type="email" class="form-control" id="email" name="email" placeholder="Email address" required />
                                        </div>
                                        <div class="col-md-6">
                                            <input type="text" class="form-control" id="phoneNumber" name="phoneNumber" placeholder="Phone number" required />
                                        </div>
                                        <div class="col-md-6">
                                            <select class="form-select" id="countrySelect" name="Nationality" onchange="checkNat()" required></select>
                                        </div>
                                        <div class="col-md-6" id="idContainer">
                                            <input type="text" class="form-control" id="natid" name="natID" placeholder="National ID or passport" required />
                                        </div>
                                        <div class="col-md-6">
                                            <input type="date" class="form-control" id="checkout" name="dOB" required />
                                        </div>
                                        <div class="col-md-6">
                                            <select class="form-select" name="gender" id="select1" required>
                                                <option value="">Select gender</option>
                                                <option value="male">Male</option>
                                                <option value="female">Female</option>
                                            </select>
                                        </div>

                                        <div class="col-12 pt-2">
                                            <span class="llb-form-section-label">Residence Details</span>
                                        </div>

                                        <div class="col-12">
                                            <input type="text" class="form-control" id="physicalAddress" name="physicalAddress" placeholder="Physical address" required />
                                        </div>
                                        <div class="col-md-6">
                                            <select class="form-select crs-country" data-region-id="one" name="countryOfResidence" id="select2" required></select>
                                        </div>
                                        <div class="col-md-6">
                                            <select class="form-select" id="one" name="province" required></select>
                                        </div>

                                        <div class="col-12 pt-2">
                                            <span class="llb-form-section-label">Security</span>
                                        </div>

                                        <div class="col-md-6">
                                            <input type="password" class="form-control" id="password" name="password" placeholder="Password" required />
                                        </div>
                                        <div class="col-md-6">
                                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Confirm password" required />
                                        </div>

                                        <div class="col-12 d-grid mt-3">
                                            <button id="myBtnciti" class="btn btn-primary btn-lg" type="submit">Create Account</button>
                                        </div>
                                    </div>
                                </form>

                                <div class="d-flex flex-wrap justify-content-between gap-3 mt-4 pt-3 border-top">
                                    <a href="/Auth/Login" class="text-decoration-none fw-semibold">Already registered? Sign in</a>
                                    <a href="/Home/FAQ" class="text-decoration-none fw-semibold">Read registration help</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function myFunction() {
        var input = document.getElementById("natid");
        if (!input) {
            return;
        }

        input.value = input.value.toUpperCase();
        var data = $("#natid").val();

        $.ajax({
            type: "GET",
            url: "/Auth/CheckId",
            contentType: "application/json; charset=utf-8",
            datatype: "text",
            data: { natid: data },
            success: function (data) {
                if (data.success === "ok") {
                    $("#idbad").html("");
                    $("#idgood").html(data.msg);
                    document.getElementById("myBtnciti").disabled = false;
                } else {
                    $("#idgood").html("");
                    $("#idbad").html(data.msg);
                    document.getElementById("myBtnciti").disabled = true;
                }
            },
            error: function (data) {
                $("#idgood").html("");
                $("#idbad").html(data.msg);
                document.getElementById("myBtnciti").disabled = true;
            }
        });
    }
</script>

<script>
    function checkNat() {
        var country = $("#countrySelect").val();
        var idContainer = $("#idContainer");

        if (country === "Zimbabwe") {
            idContainer.html(`
                <div>
                    <input type="text" class="form-control" required id="natid" onblur="myFunction()" name="natID" placeholder="National ID" />
                    <div style="color:red;" id="idbad" class="mt-2 small"></div>
                    <div style="color:green;" id="idgood" class="small"></div>
                </div>
            `);
        } else {
            idContainer.html(`
                <div>
                    <input type="text" class="form-control" required id="natid" name="natID" placeholder="Passport" />
                    <div style="color:red;" id="idbad" class="mt-2 small"></div>
                    <div style="color:green;" id="idgood" class="small"></div>
                </div>
            `);
        }
    }
</script>
