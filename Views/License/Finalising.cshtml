@{
    Layout = "_LayoutMain";

    var latestZwgExchangeRate = Convert.ToDouble(ViewBag.LatestZwgExchangeRate ?? 0);
    var paynowUsdAmount = Convert.ToDecimal(ViewBag.ApplicationInfo?.PaymentFee ?? 0);
    var paynowZwgAmount = latestZwgExchangeRate > 0
        ? paynowUsdAmount * (decimal)latestZwgExchangeRate
        : 0;

    string FormatPaymentAmount(string currency, decimal amount)
    {
        return $"{currency} {amount:N2}";
    }
}



<div class="row">
    <div class="card">
        <div class="card-body" id="_step1">
            <div class="text-center">
                <h5 class="card-title text-danger">@TempData["result"]</h5>
            </div>
            <h5 class="card-title">Finalising Application</h5>

            <table class="table table-responsive table-hover table-striped">
                <thead>

                </thead>
                <tbody>
                    <tr>
                        <td>Applicant Information</td>
                        <td><span class="text-success">Correct</span></td>
                    </tr>
                    <tr>
                        <td>Outlet Information</td>
                        <td><span class="text-success">Correct</span></td>
                    </tr>
                    <tr>
                        <td>Manager's Information</td>
                        <td><span class="text-success">Correct</span></td>
                    </tr>
                    <tr>
                        <td>Documents Information</td>
                        <td><span class="text-success">Correct</span></td>
                    </tr>

                    <tr>
                        <td>Extra Manager Fees</td>
                        <td>@ViewBag.FinalData.ManagersTotal</td>
                    </tr>

                    <tr>
                        <td>License Fees</td>
                        <td>@ViewBag.FinalData.LicencePrice</td>
                    </tr>
                    <tr>
                        <td>Final Fee</td>
                        <td>@ViewBag.FinalData.Total</td>
                    </tr>

                    <tr>
                        <td>Payment Status</td>
                        <td>
                            @if (ViewBag.Payment == null)
                            {

                                <span class="text-danger">Not paid</span>}
                            else
                            {<span class="text-success">@ViewBag.Payment.Status</span>}
                        </td>

                    </tr>

                    <tr>


                        @if (ViewBag.Payment != null && ViewBag.Payment.Status == "Paid")
                        { }
                        else if (ViewBag.Payment != null && ViewBag.Payment.Status == "awaiting verification")
                        {
                            <td>Pay Using </td>
                            <td>
                                <a href="/@ViewBag.Payment.PopDoc" target="_blank" >View POP</a>    <a href="/License/RemovePop?Id=@ViewBag.Payment.Id" class="btn btn-danger">Remove POP</a>
                            </td>
                        }
                        else
                        {
                            <td>Pay Using </td>
                            <td>
                                <button type="button"
                                        class="btn btn-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#licensePaynowCurrencyModal"
                                        data-toggle="modal"
                                        data-target="#licensePaynowCurrencyModal">
                                    Paynow
                                </button>
                                <button data-bs-toggle="modal" data-bs-target="#paymentpop" class="btn btn-primary">Upload POP</button>
                                </td>
                                }
                            

                        </tr>
                </tbody>
        </table>


        <div class="card-footer">
            <div class="text-center">
                <a href="/License/Attachments?Id=@ViewBag.ApplicationInfo.Id" class="btn btn-warning">Prev</a>
                @if (ViewBag.Queries.Count > 0)
                    {
                    <a href="/License/ResolveApplication?applicationId=@ViewBag.ApplicationInfo.Id" class="btn btn-primary">Resolve & Resubmit</a>
                    }
                    else
                    {
                    <a href="/License/Submit?Id=@ViewBag.ApplicationInfo.Id" class="btn btn-primary">Submit</a>
                    }
                </div>
        </div>
    </div>
</div>

</div>


<div class="modal fade" id="licensePaynowCurrencyModal" tabindex="-1" aria-labelledby="licensePaynowCurrencyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="get" action="/License/PaynowPayment" class="modal-content">
            <input type="hidden" name="Id" value="@ViewBag.ApplicationInfo.Id" />
            <input type="hidden" name="amount" value="@Convert.ToString(paynowUsdAmount, System.Globalization.CultureInfo.InvariantCulture)" />
            <div class="modal-header">
                <h5 class="modal-title" id="licensePaynowCurrencyModalLabel">Select Paynow Currency</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" data-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="llb-payment-price mb-3">
                    <div class="d-flex justify-content-between gap-3">
                        <span class="text-muted">USD Amount</span>
                        <strong>@FormatPaymentAmount("USD", paynowUsdAmount)</strong>
                    </div>
                    <div class="d-flex justify-content-between gap-3 mt-2">
                        <span class="text-muted">ZWG Amount</span>
                        <strong>@(latestZwgExchangeRate > 0 ? FormatPaymentAmount("ZWG", paynowZwgAmount) : "Rate not configured")</strong>
                    </div>
                    <div class="small text-muted mt-2">
                        @(latestZwgExchangeRate > 0
                            ? $"Exchange rate: 1 USD = {latestZwgExchangeRate:N4} ZWG"
                            : "No saved USD/ZWG exchange rate is available.")
                    </div>
                </div>

                <div class="d-grid gap-3">
                    <label class="llb-currency-option active" data-license-paynow-currency-option="USD">
                        <span class="d-flex align-items-center justify-content-between gap-3">
                            <span class="d-flex align-items-center gap-3">
                                <input class="form-check-input m-0" type="radio" name="currency" value="USD" checked>
                                <span>
                                    <span class="fw-semibold d-block">USD</span>
                                    <span class="text-muted small">Pay using the USD price configured in the system.</span>
                                </span>
                            </span>
                            <span class="fw-semibold text-nowrap">@FormatPaymentAmount("USD", paynowUsdAmount)</span>
                        </span>
                    </label>

                    <label class="llb-currency-option" data-license-paynow-currency-option="ZWG">
                        <span class="d-flex align-items-center justify-content-between gap-3">
                            <span class="d-flex align-items-center gap-3">
                                <input class="form-check-input m-0" type="radio" name="currency" value="ZWG">
                                <span>
                                    <span class="fw-semibold d-block">ZWG</span>
                                    <span class="text-muted small">Pay using the latest saved USD/ZWG exchange rate.</span>
                                </span>
                            </span>
                            <span class="fw-semibold text-nowrap">@(latestZwgExchangeRate > 0 ? FormatPaymentAmount("ZWG", paynowZwgAmount) : "Rate not configured")</span>
                        </span>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Make Paynow Payment</button>
            </div>
        </form>
    </div>
</div>



<div class="modal fade" id="paymentpop" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload Prof Of Payment </h5> <h5 class="modal-title" id="feetitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/License/PaymentPOP" enctype="multipart/form-data" method="post">
                <div class="modal-body">
                    <div class="row">
                        <input type="file" name="file" class="form-control" />
                        <input type="text" name="amount" value="@ViewBag.ApplicationInfo.PaymentFee" class="form-control" />
                        <input type="hidden" name="id" value="@ViewBag.ApplicationInfo.Id" class="form-control" />

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    
                        <button type="submit" class="btn btn-primary">Save changes</button>
                    


                </div>
            </form>
        </div>
    </div>
</div><!-- End Basic Modal-->

@section Scripts {
    <script>
        (function () {
            const modalElement = document.getElementById("licensePaynowCurrencyModal");
            const modalButton = document.querySelector('[data-bs-target="#licensePaynowCurrencyModal"], [data-target="#licensePaynowCurrencyModal"]');
            const options = Array.from(document.querySelectorAll("[data-license-paynow-currency-option]"));

            options.forEach(function (option) {
                option.addEventListener("click", function () {
                    const currency = option.getAttribute("data-license-paynow-currency-option");
                    const input = option.querySelector('input[type="radio"]');
                    if (input) {
                        input.checked = true;
                    }

                    options.forEach(function (item) {
                        item.classList.toggle("active", item.getAttribute("data-license-paynow-currency-option") === currency);
                    });
                });
            });

            if (modalElement && modalButton) {
                modalButton.addEventListener("click", function () {
                    if (window.bootstrap && window.bootstrap.Modal) {
                        window.bootstrap.Modal.getOrCreateInstance(modalElement).show();
                        return;
                    }

                    if (window.jQuery) {
                        window.jQuery(modalElement).modal("show");
                        return;
                    }

                    modalElement.classList.add("show");
                    modalElement.style.display = "block";
                    modalElement.removeAttribute("aria-hidden");
                });
            }
        })();
    </script>
}


<div class="modal fade" id="pop" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Adding Director Details </h5> <h5 class="modal-title" id="feetitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/License/Director" enctype="multipart/form-data" method="post">
                <div class="modal-body">
                    <div class="row">


                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div><!-- End Basic Modal-->
