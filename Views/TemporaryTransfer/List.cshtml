@using LLB.Models.ViewModel

@{
    Layout = "_LayoutMain";
    ViewData["Title"] = "Transfer List";
    ViewData["Subtitle"] = "Submitted transfer applications.";

    var listings = ViewBag.Listings as IEnumerable<ClientPostFormationListingViewModel> ?? Enumerable.Empty<ClientPostFormationListingViewModel>();

    string StatusClass(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "approved" => "llb-status-success",
            "submitted" => "llb-status-info",
            "awaiting approval" => "llb-status-info",
            "rejected" => "llb-status-danger",
            _ => "llb-status-warning"
        };
    }
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="card llb-panel-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h5 class="card-title mb-1">Transfer Applications</h5>
            <p class="text-muted mb-0">Applications you submitted against approved liquor licences.</p>
        </div>
        <a class="btn btn-primary" href="/TemporaryTransfer/Apply">Apply</a>
    </div>
    <div class="card-body">
        @if (!listings.Any())
        {
            <div class="llb-empty-state">
                <i class="bi bi-arrow-left-right"></i>
                <h5 class="fw-bold">No transfer applications</h5>
                <p class="text-muted mb-0">Your submitted transfer applications will appear here.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Trading Name</th>
                            <th>LLB Number</th>
                            <th>Transfer Type</th>
                            <th>Submitted</th>
                            <th>Licence</th>
                            <th>Region</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var listing in listings)
                        {
                            <tr>
                                <td class="fw-semibold">@listing.Reference</td>
                                <td class="fw-semibold">@listing.TradingName</td>
                                <td>@listing.LLBNumber</td>
                                <td>@listing.ServiceName</td>
                                <td>@(listing.SubmittedDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                <td>@listing.LicenseName</td>
                                <td>@listing.RegionName</td>
                                <td><span class="llb-status-pill @StatusClass(listing.Status)">@listing.Status</span></td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="@listing.ActionUrl">@listing.ActionLabel</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
