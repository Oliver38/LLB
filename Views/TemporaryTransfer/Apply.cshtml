@if (sourceApplication != null && transferApplication == null)
{
    <script>
        (function () {
            const rowsBody = document.getElementById("draftManagerRows");
            const emptyRow = document.getElementById("draftManagerEmptyRow");
            const hiddenInput = document.getElementById("managerDraftJson");
            const saveButton = document.getElementById("saveDraftManagerButton");
            const errorBox = document.getElementById("draftManagerError");
            const baseFee = Number.parseFloat("@initialBaseFee") || 0;
            const managerFee = Number.parseFloat("@initialManagerFee") || 0;
            const addDraftManagerUrl = "@Url.Action("AddDraftManager", "TemporaryTransfer")";
            const appRoot = "@Url.Content("~/")";
            const modalElement = document.getElementById("draftManagerModal");
            const modal = modalElement && window.bootstrap
                ? bootstrap.Modal.getOrCreateInstance(modalElement)
                : null;

            const nameInput = document.getElementById("draftManagerName");
            const surnameInput = document.getElementById("draftManagerSurname");
            const nationalIdInput = document.getElementById("draftManagerNationalId");
            const addressInput = document.getElementById("draftManagerAddress");
            const attachmentInput = document.getElementById("draftManagerAttachment");
            const fingerprintsInput = document.getElementById("draftManagerFingerprints");
            const form55Input = document.getElementById("draftManagerForm55");
            const antiForgeryInput = document.querySelector("#temporaryTransferDraftForm input[name='__RequestVerificationToken']");

            const managerCountDisplay = document.getElementById("draftManagerCountDisplay");
            const chargeableCountDisplay = document.getElementById("draftChargeableManagerCountDisplay");
            const additionalFeeDisplay = document.getElementById("draftAdditionalManagerFeeDisplay");
            const totalFeeDisplay = document.getElementById("draftTotalFeeDisplay");

            let draftManagers = [];

            function showError(message) {
                if (!errorBox) {
                    return;
                }

                if (!message) {
                    errorBox.textContent = "";
                    errorBox.classList.add("d-none");
                    return;
                }

                errorBox.textContent = message;
                errorBox.classList.remove("d-none");
            }

            function clearModal() {
                if (nameInput) nameInput.value = "";
                if (surnameInput) surnameInput.value = "";
                if (nationalIdInput) nationalIdInput.value = "";
                if (addressInput) addressInput.value = "";
                if (attachmentInput) attachmentInput.value = "";
                if (fingerprintsInput) fingerprintsInput.value = "";
                if (form55Input) form55Input.value = "";
                showError("");
            }

            function syncHiddenInput() {
                if (hiddenInput) {
                    hiddenInput.value = JSON.stringify(draftManagers);
                }
            }

            function updateFeeSummary() {
                const managerCount = draftManagers.length;
                const chargeableCount = Math.max(managerCount - 1, 0);
                const additionalFee = managerFee * chargeableCount;
                const totalFee = baseFee + additionalFee;

                if (managerCountDisplay) managerCountDisplay.textContent = String(managerCount);
                if (chargeableCountDisplay) chargeableCountDisplay.textContent = String(chargeableCount);
                if (additionalFeeDisplay) additionalFeeDisplay.textContent = additionalFee.toFixed(2);
                if (totalFeeDisplay) totalFeeDisplay.textContent = totalFee.toFixed(2);
            }

            function renderRows() {
                if (!rowsBody) {
                    return;
                }

                rowsBody.innerHTML = "";

                if (draftManagers.length === 0) {
                    if (emptyRow) {
                        rowsBody.appendChild(emptyRow);
                    }
                    updateFeeSummary();
                    syncHiddenInput();
                    return;
                }

                draftManagers.forEach(function (manager, index) {
                    const row = document.createElement("tr");

                    const nameCell = document.createElement("td");
                    nameCell.className = "fw-semibold";
                    nameCell.textContent = manager.name;
                    row.appendChild(nameCell);

                    const surnameCell = document.createElement("td");
                    surnameCell.textContent = manager.surname;
                    row.appendChild(surnameCell);

                    const nationalIdCell = document.createElement("td");
                    nationalIdCell.textContent = manager.nationalId;
                    row.appendChild(nationalIdCell);

                    const addressCell = document.createElement("td");
                    addressCell.textContent = manager.address;
                    row.appendChild(addressCell);

                    row.appendChild(createAttachmentCell("National ID", manager.attachment));
                    row.appendChild(createAttachmentCell("Fingerprints", manager.fingerprints));
                    row.appendChild(createAttachmentCell("Form 55", manager.form55));

                    const actionCell = document.createElement("td");
                    actionCell.className = "text-end";

                    const removeButton = document.createElement("button");
                    removeButton.type = "button";
                    removeButton.className = "btn btn-sm btn-outline-danger";
                    removeButton.setAttribute("data-index", String(index));
                    removeButton.textContent = "Remove";

                    if (removeButton) {
                        removeButton.addEventListener("click", function () {
                            draftManagers.splice(index, 1);
                            renderRows();
                        });
                    }

                    actionCell.appendChild(removeButton);
                    row.appendChild(actionCell);
                    rowsBody.appendChild(row);
                });

                updateFeeSummary();
                syncHiddenInput();
            }

            function createAttachmentCell(label, relativePath) {
                const cell = document.createElement("td");

                if (!relativePath) {
                    cell.className = "text-muted";
                    cell.textContent = "No Attachment";
                    return cell;
                }

                const link = document.createElement("a");
                link.href = appRoot + relativePath;
                link.target = "_blank";
                link.textContent = label;
                cell.appendChild(link);
                return cell;
            }

            if (saveButton) {
                saveButton.addEventListener("click", async function () {
                    const manager = {
                        name: nameInput ? nameInput.value.trim() : "",
                        surname: surnameInput ? surnameInput.value.trim() : "",
                        nationalId: nationalIdInput ? nationalIdInput.value.trim() : "",
                        address: addressInput ? addressInput.value.trim() : ""
                    };

                    if (!manager.name || !manager.surname || !manager.nationalId || !manager.address) {
                        showError("Complete the manager name, surname, national ID, and address before adding the manager.");
                        return;
                    }

                    const duplicate = draftManagers.some(function (item) {
                        return item.nationalId.toLowerCase() === manager.nationalId.toLowerCase();
                    });

                    if (duplicate) {
                        showError("A manager with the same national ID has already been added.");
                        return;
                    }

                    const attachmentFile = attachmentInput && attachmentInput.files ? attachmentInput.files[0] : null;
                    const fingerprintsFile = fingerprintsInput && fingerprintsInput.files ? fingerprintsInput.files[0] : null;
                    const form55File = form55Input && form55Input.files ? form55Input.files[0] : null;

                    if (!attachmentFile || !fingerprintsFile || !form55File) {
                        showError("Upload the manager national ID copy, fingerprints, and Form 55 before adding the manager.");
                        return;
                    }

                    if (!antiForgeryInput || !antiForgeryInput.value) {
                        showError("The form security token is missing. Refresh the page and try again.");
                        return;
                    }

                    const originalButtonText = saveButton.textContent;
                    saveButton.disabled = true;
                    saveButton.textContent = "Saving...";

                    const formData = new FormData();
                    formData.append("__RequestVerificationToken", antiForgeryInput.value);
                    formData.append("llbNumber", "@(sourceApplication.LLBNum ?? string.Empty)");
                    formData.append("name", manager.name);
                    formData.append("surname", manager.surname);
                    formData.append("nationalId", manager.nationalId);
                    formData.append("address", manager.address);
                    formData.append("file", attachmentFile);
                    formData.append("fileb", fingerprintsFile);
                    formData.append("form55", form55File);

                    try {
                        const response = await fetch(addDraftManagerUrl, {
                            method: "POST",
                            body: formData
                        });

                        const payload = await response.json();
                        if (!response.ok || !payload.success || !payload.manager) {
                            showError(payload && payload.message
                                ? payload.message
                                : "The manager could not be added. Try again.");
                            return;
                        }

                        draftManagers.push(payload.manager);
                        renderRows();
                        clearModal();
                        if (modal) {
                            modal.hide();
                        }
                    } catch {
                        showError("The manager could not be added. Check the files and try again.");
                    } finally {
                        saveButton.disabled = false;
                        saveButton.textContent = originalButtonText || "Add Manager";
                    }
                });
            }

            if (modalElement) {
                modalElement.addEventListener("hidden.bs.modal", clearModal);
            }

            renderRows();
        })();
    </script>
}
