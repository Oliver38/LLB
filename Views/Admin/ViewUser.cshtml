@model LLB.Models.ViewModel.AdminUserDetailViewModel

@{
    Layout = "_LayoutMain";

    var canUnlock = Model.IsLockedOut;
    var canDeactivate = !string.Equals(User?.Identity?.Name, Model.Email, StringComparison.OrdinalIgnoreCase);
    var statusClass = !Model.IsActive
        ? "llb-status-danger"
        : Model.IsLockedOut
            ? "llb-status-warning"
            : "llb-status-success";
    var statusText = !Model.IsActive
        ? "Inactive"
        : Model.IsLockedOut
            ? "Locked"
            : "Active";
}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Account Status</p>
                    <h3>@statusText</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-person-badge"></i></span>
            </div>
            <p>Current portal access state for this account.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Roles</p>
                    <h3>@Model.SelectedRoles.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-shield-check"></i></span>
            </div>
            <p>Assigned roles that determine dashboards, menus, and workflow responsibilities.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Access Failed Count</p>
                    <h3>@Model.AccessFailedCount</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-exclamation-triangle"></i></span>
            </div>
            <p>Failed login attempts currently recorded for the account.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Leave Status</p>
                    <h3>@Model.LeaveStatus</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-calendar-event"></i></span>
            </div>
            <p>Operational status for internal assignment and availability management.</p>
        </div>
    </div>
</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success border-0 rounded-4">@TempData["success"]</div>
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger border-0 rounded-4">@TempData["error"]</div>
}

@if (TempData["generatedPassword"] != null)
{
    <div class="alert alert-warning border-0 rounded-4">
        Temporary password: <strong>@TempData["generatedPassword"]</strong>
    </div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card llb-panel-card h-100">
            <div class="card-header">
                <h5 class="card-title">Account Summary</h5>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="fw-semibold fs-5">@Model.Name @Model.LastName</div>
                    <div class="text-muted">@Model.Email</div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="llb-status-pill @statusClass">@statusText</span>
                    @foreach (var role in Model.SelectedRoles)
                    {
                        <span class="llb-chip">@role</span>
                    }
                </div>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <tbody>
                            <tr>
                                <th>User Name</th>
                                <td>@Model.UserName</td>
                            </tr>
                            <tr>
                                <th>Email Confirmed</th>
                                <td>@(Model.EmailConfirmed ? "Yes" : "No")</td>
                            </tr>
                            <tr>
                                <th>Phone Confirmed</th>
                                <td>@(Model.PhoneNumberConfirmed ? "Yes" : "No")</td>
                            </tr>
                            <tr>
                                <th>Application Date</th>
                                <td>@(Model.DateOfApplication?.ToString("dd MMM yyyy") ?? "-")</td>
                            </tr>
                            <tr>
                                <th>Created By</th>
                                <td>@(string.IsNullOrWhiteSpace(Model.ApplicationBy) ? "-" : Model.ApplicationBy)</td>
                            </tr>
                            <tr>
                                <th>Lockout End</th>
                                <td>@(Model.LockoutEnd?.ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <form method="post" action="/Admin/UpdateActivation" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="activate" value="@(!Model.IsActive)" />
                        <button type="submit" class="btn @(Model.IsActive ? "btn-outline-danger" : "btn-outline-success")" @(canDeactivate ? null : "disabled")>
                            @(Model.IsActive ? "Deactivate User" : "Activate User")
                        </button>
                    </form>

                    @if (canUnlock)
                    {
                        <form method="post" action="/Admin/UnlockUser" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-primary">Unlock Account</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card llb-panel-card mb-4">
            <div class="card-header">
                <h5 class="card-title">Profile Details</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Admin/UpdateUser" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Surname</label>
                        <input asp-for="LastName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nationality</label>
                        <select class="form-select" id="countrySelect" name="Nationality">
                            @if (!string.IsNullOrWhiteSpace(Model.Nationality))
                            {
                                <option selected value="@Model.Nationality">@Model.Nationality</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">National ID / Passport</label>
                        <input asp-for="NatID" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date Of Birth</label>
                        <input asp-for="DOB" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select gender</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Physical Address</label>
                        <textarea asp-for="PhysicalAddress" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Country Of Residence</label>
                        <select asp-for="CountryOfResidence" class="form-select crs-country" data-region-id="detail-province"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Province</label>
                        <select asp-for="Province" class="form-select" id="detail-province"></select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Save Profile Changes</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card llb-panel-card mb-4">
            <div class="card-header">
                <h5 class="card-title">Role Management</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Admin/UpdateRoles" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="col-12">
                        <div class="row g-2">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <div class="col-md-6 col-xl-4">
                                    <label class="border rounded-4 p-3 w-100 d-flex align-items-center gap-2">
                                        <input class="form-check-input mt-0" type="checkbox" name="selectedRoles" value="@role"
                                               @(Model.SelectedRoles.Any(selected => string.Equals(selected, role, StringComparison.OrdinalIgnoreCase)) ? "checked" : null) />
                                        <span>@role</span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Update Roles</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card llb-panel-card h-100">
                    <div class="card-header">
                        <h5 class="card-title">Leave Status</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" action="/Admin/UpdateLeaveStatus" class="row g-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="col-12">
                                <label class="form-label">Current Leave Status</label>
                                <select name="leaveStatus" class="form-select">
                                    @foreach (var status in Model.LeaveStatusOptions)
                                    {
                                        <option value="@status" selected="@(Model.LeaveStatus == status ? "selected" : null)">@status</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary">Update Leave Status</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card llb-panel-card h-100">
                    <div class="card-header">
                        <h5 class="card-title">Password Reset</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">
                            Leave the password field empty to generate a strong temporary password for the user.
                        </p>
                        <form method="post" action="/Admin/ResetPassword" class="row g-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@Model.Id" />
                            <div class="col-12">
                                <label class="form-label">Temporary Password</label>
                                <input type="text" name="newPassword" class="form-control" placeholder="Optional custom temporary password" />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-outline-primary">Reset Password</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
