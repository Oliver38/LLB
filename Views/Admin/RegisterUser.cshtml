@model LLB.Models.ViewModel.AdminUserUpsertViewModel

@{
    Layout = "_LayoutMain";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card llb-stat-card h-100">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Provisioning</p>
                    <h3>New User</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-person-plus"></i></span>
            </div>
            <p class="mb-3">Create an internal or external account, assign the correct roles, and decide whether the account should start active.</p>
            <ul class="llb-soft-list">
                <li>
                    <i class="bi bi-check2-circle"></i>
                    <div>If no password is entered, the system will generate a strong temporary password.</div>
                </li>
                <li>
                    <i class="bi bi-check2-circle"></i>
                    <div>Internal-facing roles automatically retain the supporting <strong>internal</strong> role.</div>
                </li>
                <li>
                    <i class="bi bi-check2-circle"></i>
                    <div>You can edit profile details, roles, access status, and leave status later from the user detail page.</div>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card llb-panel-card">
            <div class="card-header">
                <h5 class="card-title">Register User</h5>
            </div>
            <div class="card-body">
                @if (TempData["success"] != null)
                {
                    <div class="alert alert-success border-0 rounded-4">@TempData["success"]</div>
                }

                @if (TempData["error"] != null)
                {
                    <div class="alert alert-danger border-0 rounded-4">@TempData["error"]</div>
                }

                <form method="post" action="/Admin/RegisterUser" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Surname</label>
                        <input asp-for="LastName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nationality</label>
                        <select class="form-select" id="countrySelect" name="Nationality">
                            @if (!string.IsNullOrWhiteSpace(Model.Nationality))
                            {
                                <option selected value="@Model.Nationality">@Model.Nationality</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">National ID / Passport</label>
                        <input asp-for="NatID" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date Of Birth</label>
                        <input asp-for="DOB" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select gender</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Physical Address</label>
                        <textarea asp-for="PhysicalAddress" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Country Of Residence</label>
                        <select asp-for="CountryOfResidence" class="form-select crs-country" data-region-id="admin-province"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Province</label>
                        <select asp-for="Province" class="form-select" id="admin-province"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" />
                        <small class="text-muted">Leave blank to auto-generate a strong temporary password.</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Leave Status</label>
                        <select asp-for="LeaveStatus" class="form-select">
                            @foreach (var status in Model.LeaveStatusOptions)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check form-switch mt-3">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="IsActive">Start account as active</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Assigned Roles</label>
                        <div class="row g-2">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <div class="col-md-6 col-xl-4">
                                    <label class="border rounded-4 p-3 w-100 d-flex align-items-center gap-2">
                                        <input class="form-check-input mt-0" type="checkbox" name="SelectedRoles" value="@role"
                                               @(Model.SelectedRoles.Contains(role, StringComparer.OrdinalIgnoreCase) ? "checked" : null) />
                                        <span>@role</span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-12 d-flex flex-wrap gap-2 pt-2">
                        <button type="submit" class="btn btn-primary">Create User</button>
                        <a href="/Admin/InternalUsers" class="btn btn-outline-primary">Back To Directory</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
