@{
    Layout = "_LayoutMain";

    string Checked(string? actual, string expected)
    {
        var selected = string.IsNullOrWhiteSpace(actual) ? "true" : actual;
        return string.Equals(selected, expected, StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty;
    }
}


