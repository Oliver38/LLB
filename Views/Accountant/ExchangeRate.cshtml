@using System.Globalization
@model LLB.Models.ViewModel.AccountantExchangeRateViewModel

@{
    Layout = "_LayoutMain";
    var suggestedRateValue = Model.Average?.ToString("0.0000", CultureInfo.InvariantCulture)
        ?? Model.TodayStoredRate?.ExchangeRate?.ToString("0.0000", CultureInfo.InvariantCulture)
        ?? string.Empty;
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="row g-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div>
                        <h5 class="card-title mb-1">RBZ USD/ZWG Exchange Rate</h5>
                        <p class="text-muted mb-0">Scanned directly from the Reserve Bank of Zimbabwe website.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-primary" href="/Accountant/ExchangeRate">
                            <i class="bi bi-arrow-clockwise me-2"></i>Refresh Scan
                        </a>
                        <a class="btn btn-light border" href="@Model.SourceUrl" target="_blank" rel="noopener noreferrer">
                            <i class="bi bi-box-arrow-up-right me-2"></i>Open RBZ
                        </a>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-uppercase text-muted small fw-semibold mb-1">Exchange Date</div>
                            <div class="fs-5 fw-semibold">@(Model.ExchangeDate?.ToString("dd-MM-yyyy") ?? "Unavailable")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-uppercase text-muted small fw-semibold mb-1">Currency Pair</div>
                            <div class="fs-5 fw-semibold">@Model.CurrencyPair</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-uppercase text-muted small fw-semibold mb-1">Scanned At</div>
                            <div class="fs-5 fw-semibold">@Model.RetrievedAt.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>

                @if (!Model.HasRate)
                {
                    <div class="alert alert-warning mt-4 mb-0">
                        @(Model.ErrorMessage ?? "The RBZ exchange-rate scan did not return a usable USD/ZWG result.")
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Today's Saved Rate</h5>
                @if (Model.TodayStoredRate == null)
                {
                    <div class="alert alert-warning mb-0">
                        No USD/ZWG exchange rate has been saved for today yet.
                    </div>
                }
                else
                {
                    <div class="border rounded p-3">
                        <div class="text-uppercase text-muted small fw-semibold mb-1">Date</div>
                        <div class="fs-6 fw-semibold mb-3">@Model.TodayStoredRate.Date.ToString("dd-MM-yyyy")</div>

                        <div class="text-uppercase text-muted small fw-semibold mb-1">Updater Username</div>
                        <div class="fs-6 fw-semibold mb-3">@Model.TodayStoredRate.UpdaterUserName</div>

                        <div class="text-uppercase text-muted small fw-semibold mb-1">Exchange Rate</div>
                        <div class="fs-4 fw-bold">@Model.TodayStoredRate.ExchangeRate?.ToString("0.0000", CultureInfo.InvariantCulture)</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Update Daily Exchange Rate</h5>
                <p class="text-muted">Use the RBZ scanned average as the daily system exchange rate, or adjust it before saving.</p>

                <form method="post" action="/Accountant/UpdateExchangeRate" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-6">
                        <label class="form-label">Exchange Rate To Save</label>
                        <input
                            type="number"
                            name="exchangeRate"
                            step="0.0001"
                            min="0"
                            class="form-control"
                            value="@suggestedRateValue" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Rate Date</label>
                        <input
                            type="text"
                            class="form-control"
                            value="@DateTime.Today.ToString("dd-MM-yyyy")"
                            readonly />
                    </div>
                    <div class="col-12">
                        <div class="small text-muted">
                            Suggested value comes from the RBZ `AVG` column when available.
                        </div>
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-2"></i>Save Today's Rate
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Interbank USD/ZWG Rate Table</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Market</th>
                                <th>Currency</th>
                                <th class="text-end">Bid</th>
                                <th class="text-end">Ask</th>
                                <th class="text-end">Average</th>
                                <th>Source</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.HasRate)
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">No USD/ZWG exchange-rate record could be scanned from RBZ.</td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td>@Model.ExchangeDate?.ToString("dd-MM-yyyy")</td>
                                    <td>@Model.Market</td>
                                    <td class="fw-semibold">@Model.CurrencyPair</td>
                                    <td class="text-end">@Model.Bid?.ToString("0.0000", CultureInfo.InvariantCulture)</td>
                                    <td class="text-end">@Model.Ask?.ToString("0.0000", CultureInfo.InvariantCulture)</td>
                                    <td class="text-end">@Model.Average?.ToString("0.0000", CultureInfo.InvariantCulture)</td>
                                    <td>
                                        <a href="@Model.SourceUrl" target="_blank" rel="noopener noreferrer">@Model.SourceName</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Saved Exchange Rate History</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Updater Username</th>
                                <th class="text-end">Exchange Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.StoredRates.Count == 0)
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-4">No exchange rates have been saved yet.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model.StoredRates)
                                {
                                    <tr>
                                        <td>@item.Date.ToString("dd-MM-yyyy")</td>
                                        <td class="fw-semibold">@item.UpdaterUserName</td>
                                        <td class="text-end">@item.ExchangeRate?.ToString("0.0000", CultureInfo.InvariantCulture)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
