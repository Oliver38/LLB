@using System.Linq
@using LLB.Models

@{
    Layout = "_LayoutMain";

    var extendedHoursRecord = ViewBag.ExtendedHoursRecord as ExtendedHours;
    var extendedHoursRecords = ViewBag.ExtendedHoursRecords as IEnumerable<ExtendedHours> ?? Enumerable.Empty<ExtendedHours>();
    var editableExtendedHoursRecord = ViewBag.EditableExtendedHoursRecord as ExtendedHours;
    var payment = ViewBag.Payment as Payments;
    bool canStartNewExtendedHours = ViewBag.CanStartNewExtendedHours is bool canStart && canStart;
    bool canSubmitExtendedHours = ViewBag.CanSubmitExtendedHours is bool canSubmit && canSubmit;
    bool isExplicitExtendedHoursSelection = ViewBag.IsExplicitExtendedHoursSelection is bool isExplicit && isExplicit;
    bool hasPendingSubmittedExtendedHours = ViewBag.HasPendingSubmittedExtendedHours is bool hasPending && hasPending;
    bool hasAnotherSubmittedExtendedHours = ViewBag.HasAnotherSubmittedExtendedHours is bool hasAnotherSubmitted && hasAnotherSubmitted;
    bool isExtendedHoursPaid = ViewBag.IsExtendedHoursPaid is bool paid && paid;
    bool isEditableExtendedHoursPaid = ViewBag.IsEditableExtendedHoursPaid is bool editablePaid && editablePaid;
    bool hasEditableInProgressExtendedHours = editableExtendedHoursRecord != null
        && string.Equals(editableExtendedHoursRecord.Status, "inprogress", StringComparison.OrdinalIgnoreCase);
    string process = ViewBag.Process as string ?? "EXH";
    string? extendedHoursWarning = ViewBag.ExtendedHoursWarning as string;
    string currentExtendedHoursId = extendedHoursRecord?.Id ?? string.Empty;
    string applicationId = ViewBag.Appinfo?.Id ?? string.Empty;
    string outletName = Convert.ToString(ViewBag.Outletinfo?.TradingName) ?? "this outlet";
    DateTime? displayedRequestedDate = null;
    string displayedStatus = extendedHoursRecord?.Status ?? "Not started";
    string displayedPaymentStatus = payment?.PaymentStatus ?? payment?.Status ?? extendedHoursRecord?.PaymentStatus ?? "Not Paid";
    string displayedPaynowReference = payment?.PaynowRef ?? "N/A";
    string displayedJustification = extendedHoursRecord?.ReasonForExtention ?? "Not provided yet";
    string selectedExtendedHoursStatus = extendedHoursRecord?.Status ?? string.Empty;

    if (extendedHoursRecord != null && extendedHoursRecord.ExtendedHoursDate != DateTime.MinValue)
    {
        displayedRequestedDate = extendedHoursRecord.ExtendedHoursDate;
    }

    string editableExtendedHoursDateValue = editableExtendedHoursRecord != null
        && editableExtendedHoursRecord.ExtendedHoursDate != DateTime.MinValue
        ? editableExtendedHoursRecord.ExtendedHoursDate.ToString("yyyy-MM-dd")
        : string.Empty;
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

@if (!string.IsNullOrWhiteSpace(extendedHoursWarning))
{
    <div class="alert alert-info">@extendedHoursWarning</div>
}

<div class="card mb-4">
    <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div class="card-title mb-0">Selected Extended Hours Application For @outletName</div>
        <div class="d-flex align-items-center gap-2">
            @if (extendedHoursRecord != null)
            {
                <span class="badge bg-light text-dark border">@extendedHoursRecord.Reference</span>
            }

            @if (extendedHoursRecords.Any())
            {
                <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#existingExtendedHoursModal">
                    Existing Extended Hours Applications
                </button>
            }
            else
            {
                <button class="btn btn-sm btn-outline-secondary" type="button" disabled>
                    Existing Extended Hours Applications
                </button>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <tbody class="table-light">
                    <tr>
                        <th>Outlet Name</th>
                        <td>@outletName</td>
                    </tr>
                    <tr>
                        <th>Licence</th>
                        <td>@ViewBag.License?.LicenseName</td>
                    </tr>
                    <tr>
                        <th>Region</th>
                        <td>@ViewBag.Region?.RegionName</td>
                    </tr>
                    <tr>
                        <th>Extended Hours Reference</th>
                        <td>@(extendedHoursRecord?.Reference ?? "Not generated yet")</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>@displayedStatus</td>
                    </tr>
                    <tr>
                        <th>Fee</th>
                        <td>@ViewBag.TotalFee</td>
                    </tr>
                    <tr>
                        <th>Requested Date</th>
                        <td>
                            @if (displayedRequestedDate.HasValue)
                            {
                                @displayedRequestedDate.Value.ToString("yyyy-MM-dd")
                            }
                            else
                            {
                                <span>Not selected</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Payment Status</th>
                        <td>@displayedPaymentStatus</td>
                    </tr>
                    <tr>
                        <th>Paynow Reference</th>
                        <td>@displayedPaynowReference</td>
                    </tr>
                    <tr>
                        <th>Justification</th>
                        <td>@displayedJustification</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">Create Extended Hours Application</h5>
    </div>
    <div class="card-body">
        @if (hasEditableInProgressExtendedHours)
        {
            @if (isEditableExtendedHoursPaid)
            {
                <div class="alert alert-info mb-0">
                    This in-progress extended hours application has already been paid for. Its details are locked and can no longer be edited.
                </div>
            }
            else
            {
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <div class="fw-semibold">An in-progress extended hours application already exists.</div>
                        <div class="text-muted">Edit the current draft to update the requested date or justification before payment and submission.</div>
                    </div>
                    <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#editExtendedHoursModal">
                        Edit Current Application
                    </button>
                </div>
            }
        }
        else if (canStartNewExtendedHours)
        {
            <form action="/Postprocess/SaveExtendedHours" method="post">
                <input type="hidden" name="applicationId" value="@applicationId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Extended Hours Date</label>
                        <input type="date" name="extendedHoursDate" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Justification</label>
                        <textarea name="reasonForExtention" class="form-control" rows="5"></textarea>
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button class="btn btn-primary" type="submit">Initialize New Application</button>
                    </div>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-warning mb-0">
                A submitted extended hours application is already awaiting a decision. Create another one after it has been approved or rejected.
            </div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">Submission Steps</h5>
    </div>
    <div class="card-body">
@if (extendedHoursRecord == null)
{
    @if (canStartNewExtendedHours)
    {
        <div class="d-flex flex-column gap-3">
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 1: Create The Application</div>
                <div class="text-muted">Use the create form above to initialize a fresh extended hours request for this licence.</div>
            </div>
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 2: Make Payment</div>
                <div class="text-muted">Once the new application is initialized, open it and complete its Paynow payment.</div>
            </div>
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 3: Submit To The Secretary</div>
                <div class="text-muted">After payment is confirmed, continue the same application to send it for review.</div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-light border mb-0">
            Select the submitted extended hours application from the button above to review its current status.
        </div>
    }
}
else if (string.Equals(selectedExtendedHoursStatus, "submitted", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-warning mb-0">
        This extended hours application has already been submitted. The Secretary will approve or reject it after examination.
    </div>
}
else if (string.Equals(selectedExtendedHoursStatus, "approved", StringComparison.OrdinalIgnoreCase) && isExplicitExtendedHoursSelection)
{
    <div class="alert alert-success d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-0">
        <span>This extended hours application has been approved.</span>
        <a class="btn btn-success" href="/Documents/ExtendedHoursLicense?searchref=@currentExtendedHoursId">View Certificate</a>
    </div>
}
else if (string.Equals(selectedExtendedHoursStatus, "rejected", StringComparison.OrdinalIgnoreCase) && isExplicitExtendedHoursSelection)
{
    <div class="alert alert-danger mb-0">
        This extended hours application has been rejected.
    </div>
}
else if (!string.IsNullOrWhiteSpace(currentExtendedHoursId))
{
    <div class="alert alert-info">
        This extended hours application has been initialized. Payment and submission are handled independently for this request.
    </div>

        <div class="d-flex flex-column gap-3">
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 1: Application Initialized</div>
                <div class="text-muted">
                    The extended hours date and justification have already been captured for this application.
                    @if (hasEditableInProgressExtendedHours
                        && string.Equals(editableExtendedHoursRecord?.Id, currentExtendedHoursId, StringComparison.OrdinalIgnoreCase)
                        && !isEditableExtendedHoursPaid)
                    {
                        <button class="btn btn-link btn-sm p-0 ms-1 align-baseline" type="button" data-bs-toggle="modal" data-bs-target="#editExtendedHoursModal">
                            Edit details
                        </button>
                    }
                </div>
                @if (hasEditableInProgressExtendedHours
                    && string.Equals(editableExtendedHoursRecord?.Id, currentExtendedHoursId, StringComparison.OrdinalIgnoreCase)
                    && isEditableExtendedHoursPaid)
                {
                    <div class="mt-2">
                        <span class="badge bg-secondary">Locked after payment</span>
                    </div>
                }
            </div>
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 2: Make Payment</div>
            <div class="text-muted mb-3">Each new extended hours application requires its own Paynow payment.</div>
            @if (!isExtendedHoursPaid)
            {
                <a class="btn btn-primary" href="/Postprocess/ExtendedHoursPayment?id=@applicationId&extId=@currentExtendedHoursId&amount=@ViewBag.TotalFee&service=extendedhours&process=@process">
                    Make Payment
                </a>
            }
            else
            {
                <span class="badge bg-success">Payment received</span>
            }
        </div>
        <div class="border rounded p-3">
            <div class="fw-semibold mb-1">Step 3: Continue To Submit</div>
            <div class="text-muted mb-3">After Paynow confirms payment, continue to send the application to the Secretary.</div>
            @if (canSubmitExtendedHours)
            {
                <form action="/Postprocess/SubmitExtendedHours" method="post" class="d-inline">
                    <input type="hidden" name="extId" value="@currentExtendedHoursId" />
                    <button class="btn btn-success" type="submit">Continue</button>
                </form>
            }
            else if (hasAnotherSubmittedExtendedHours)
            {
                <span class="badge bg-warning text-dark">Another submitted application is awaiting review</span>
            }
            else if (isExtendedHoursPaid)
            {
                <span class="badge bg-secondary">Ready for submission</span>
            }
            else
            {
                <span class="badge bg-light text-dark border">Complete payment first</span>
            }
        </div>
        @if (hasPendingSubmittedExtendedHours && hasAnotherSubmittedExtendedHours)
        {
            <div class="alert alert-warning mb-0">
                Another extended hours application for this licence is already with the Secretary. This draft cannot be submitted until that application has been approved or rejected.
            </div>
        }
    </div>
}
    </div>
</div>

@if (hasEditableInProgressExtendedHours && !isEditableExtendedHoursPaid)
{
    <div class="modal fade" id="editExtendedHoursModal" tabindex="-1" aria-labelledby="editExtendedHoursModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form action="/Postprocess/SaveExtendedHours" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editExtendedHoursModalLabel">Edit Extended Hours Application</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="applicationId" value="@applicationId" />
                        <input type="hidden" name="extId" value="@editableExtendedHoursRecord?.Id" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Extended Hours Date</label>
                                <input type="date" name="extendedHoursDate" class="form-control" value="@editableExtendedHoursDateValue" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Justification</label>
                                <textarea name="reasonForExtention" class="form-control" rows="5" required>@(editableExtendedHoursRecord?.ReasonForExtention ?? string.Empty)</textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button class="btn btn-primary" type="submit">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="existingExtendedHoursModal" tabindex="-1" aria-labelledby="existingExtendedHoursModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="existingExtendedHoursModalLabel">Existing Extended Hours Applications</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (!extendedHoursRecords.Any())
                {
                    <div class="alert alert-light border mb-0">
                        No extended hours applications have been created for this licence yet.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>Requested Date</th>
                                    <th>Payment Status</th>
                                    <th>Status</th>
                                    <th>Updated</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in extendedHoursRecords)
                                {
                                    var itemPaymentStatus = item.PaymentStatus ?? "Not Paid";
                                    var itemStatus = item.Status ?? "Unknown";

                                    <tr>
                                        <td class="fw-semibold">@item.Reference</td>
                                        <td>@(item.ExtendedHoursDate == DateTime.MinValue ? "Not selected" : item.ExtendedHoursDate.ToString("yyyy-MM-dd"))</td>
                                        <td>@itemPaymentStatus</td>
                                        <td>@itemStatus</td>
                                        <td>@item.DateUpdated.ToString("yyyy-MM-dd")</td>
                                        <td class="text-end">
                                            @if (item.Id == currentExtendedHoursId)
                                            {
                                                <span class="badge bg-primary">Selected</span>
                                            }
                                            else
                                            {
                                                <a class="btn btn-sm btn-outline-primary" href="/Postprocess/ExtendedHours?id=@applicationId&process=@process&extId=@item.Id">Open</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
