@{
    Layout = "_LayoutMain";
    var canSubmitInspection = ViewBag.CanSubmitInspection == true;
    var canMakeInspectionPayment = ViewBag.CanMakeInspectionPayment == true;
    var hasActiveInspectionPayment = ViewBag.HasActiveInspectionPayment == true;
    var inspectionPaymentRedirect = ViewBag.InspectionPaymentRedirect as string;
}



<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="card-title mb-0">Inspection For @ViewBag.Outletinfo.TradingName</div>
        @*<button class="btn btn-primary" onclick="PostFormationModal()">Add Post Formation Fee</button>*@
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <tbody class="table-light">

                    <tr>
                        <th>Outlet Name</th>
                        <td>
                            @ViewBag.Outletinfo.TradingName
                        </td>
                    </tr>
                    @if (ViewBag.Inspectiondata != null)
                    {
                        <tr>
                            <th>Inspection Reference</th>
                            <td>
                                @(ViewBag.Inspectiondata.Reference ?? "N/A")
                            </td>
                        </tr>
                    }
                    <tr>
                        <th>License ExpiryDate</th>
                        <td>
                            @ViewBag.Appinfo.ExpiryDate
                        </td>
                    </tr>
                    <tr>
                        <th>Fee</th>
                        <td>
                            @ViewBag.Fee
                        </td>
                    </tr>




                    <tr>
                        <th>Total Fee</th>
                        <td>@ViewBag.TotalFee</td>
                    </tr>
                    <tr>
                        <th>Payment Status</th>
                        <td>
                    @if (ViewBag.Payment == null)
                            {<span style="color:red"> Not Paid</span>}
                            else
                            { <span class="@(ViewBag.Payment.Status == "Paid" ? "text-success" : "text-danger")"> @ViewBag.Payment.Status</span>}
                        </td>
                    </tr>


                    @*[Key]
            // Liquor Outlet Info
            public string? Id { get; set; }
            public string? ApplicationId { get; set; }
            public string? UserId { get; set; }
            public string? PreviousExpiry { get; set; }
            public string? FeePaid { get; set; }
            public string? PenaltyPaid { get; set; }
            public string? PaymentStatus { get; set; }
            public string? LLBNumber { get; set; }

            public string? Service { get; set; }
            public DateTime DateApplied { get; set; }
            public DateTime DateUpdated { get; set; }*@




                    @if (ViewBag.Inspectiondata != null)
                    {
                        <tr>
                            <td>
                                Your inspection application has been submitted and is in progress.
                            </td>
                            <td>
                                <a class="btn btn-primary" href="/Home/Dashboard">
                                    Continue
                                </a>
                            </td>
                        </tr>
                    }
                    else if (canSubmitInspection)
                    {
                        <form action="/Postprocess/PostInspection" enctype="multipart/form-data" method="post">
                            <tr>
                                <th>Inspection Submission </th>
                                <td><span class="text-success"> Ready for submission</span></td>
                            </tr>
                            <tr>
                                <th>
                                    <input type="hidden" name="service" value="Inspection" />
                                    <input type="hidden" name="lLBNumber" value="@ViewBag.Appinfo.LLBNum" />
                                    <input type="hidden" name="PaymentStatus" value="Paid" />
                                    <input type="hidden" name="penaltyPaid" value="@ViewBag.Penalty" />
                                    <input type="hidden" name="feePaid" value="@ViewBag.Fee" />
                                    <input type="hidden" name="previousExpiry" value="@ViewBag.Appinfo.ExpiryDate" />
                                    <input type="hidden" name="applicationId" value="@ViewBag.Appinfo.Id" />
                                </th>
                                <td><button class="btn btn-primary" type="submit"> Submit For Inspection</button></td>
                            </tr>
                        </form>
                    }
                    else if (canMakeInspectionPayment)
                    {
                        <tr>
                            <td colspan="2"><button type="button" class="btn btn-primary" onclick="Payment()"> Pay For Inspection</button></td>
                        </tr>
                    }
                    else if (hasActiveInspectionPayment)
                    {
                        <tr>
                            <td colspan="2">
                                Complete the current inspection payment before starting another inspection application.
                                @if (!string.IsNullOrWhiteSpace(inspectionPaymentRedirect))
                                {
                                    <a class="btn btn-primary ms-2" href="@inspectionPaymentRedirect">Continue Payment</a>
                                }
                            </td>
                        </tr>
                    }






                    </tbody>

                </table>
        </div>`
    </div>
</div>




<!-- Basic Modal -->

<div class="modal fade" id="PaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Post Fomation For </h5> &nbsp;<b><h5 class="modal-title" id="feetitle"></h5></b>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form action="/Postprocess/AddFee" enctype="multipart/form-data" method="post">

                    <div class="col-md-12">
                        @*<label for="inputName5" class="form-label">Select Post Formation Process</label>
                            <input type="hidden" name="id" class="form-control" value="" id="ApplicationId">*@



                        <form action="/Postprocess/UpdateFee" enctype="multipart/form-data" method="post">


                            <table class="table table-bordered table-hover">
                                <tbody class="table-light">

                                    <tr>
                                        <th>Outlet Name</th>
                                        <td>
                                            @ViewBag.Outletinfo.TradingName
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>License ExpiryDate</th>
                                        <td>
                                            @ViewBag.Appinfo.ExpiryDate
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Fee</th>
                                        <td>
                                            @ViewBag.Fee
                                        </td>
                                    </tr>

                                   

                                   
                                    <tr>
                                        <th>Total Fee</th>
                                        <td>@ViewBag.TotalFee</td>
                                    </tr>
                                    <tr>
                                        <th>Payment Status</th>
                                        <td>
                                            @if (ViewBag.Payment == null)
                                            {<span style="color:red"> Not Paid</span>}
                                            else
                                            { <span class="@(ViewBag.Payment.Status == "Paid" ? "text-success" : "text-danger")"> @ViewBag.Payment.Status</span>}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="2">

                                            <p><b>NB:</b> After making this payment,the system will recognise that you have made a payment. You are required to return and submit your inspection </p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th></th>
                                        <td>
                                            @if (canMakeInspectionPayment)
                                            {
                                                <a class="btn btn-primary" href="/Postpayments/Paynow?id=@ViewBag.Appinfo.Id&amount=@ViewBag.TotalFee&service=inspection&process=@ViewBag.Process">
                                                    Make Payment
                                                </a>
                                            }
                                            else if (hasActiveInspectionPayment && !string.IsNullOrWhiteSpace(inspectionPaymentRedirect))
                                            {
                                                <a class="btn btn-primary" href="@inspectionPaymentRedirect">Continue Payment</a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Payment is not available while an inspection is in progress.</span>
                                            }
                                        </td>
                                    </tr>
                                </tbody>

                            </table>
                        </form>


                    </div>



                    @*<div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button type="submit" class="btn btn-primary">Submit</button>


                        </div>*@
                </form>
            </div>
        </div>
    </div>
</div><!-- End Basic Modal-->
<!-- Basic Modal -->



<script>function Payment() {
        // alert(Id + Name + CityFee + Municipalty + TownFee + RDCFee);

        $('#PaymentModal').modal('show');

    }</script>
