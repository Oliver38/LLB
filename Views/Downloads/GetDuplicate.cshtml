@{
    Layout = "_LayoutMain";
    var paymentStatus = ViewBag.Payment?.PaymentStatus ?? "Not Started";
    var duplicateStatus = ViewBag.Download?.PaymentStatus ?? "Closed";
    var downloadStatus = ViewBag.Download?.Status ?? "Closed";
    var currentTask = ViewBag.CurrentTask;
}

<div class="row">
    <div class="card">
        <div class="card-header">
            @if (TempData["result"] != null)
            {
                <div class="alert alert-info mb-3">@TempData["result"]</div>
            }
            <h5 class="card-title mb-0">Licence Duplicate Request</h5>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <tbody class="table-light">
                        <tr>
                            <th>Outlet Name</th>
                            <td>@ViewBag.OutletInfo?.TradingName</td>
                        </tr>
                        <tr>
                            <th>LLB Number</th>
                            <td>@ViewBag.AppInfo?.LLBNum</td>
                        </tr>
                        <tr>
                            <th>Province</th>
                            <td>@ViewBag.OutletInfo?.Province</td>
                        </tr>
                        <tr>
                            <th>Council</th>
                            <td>@ViewBag.OutletInfo?.Council</td>
                        </tr>
                        <tr>
                            <th>Download Status</th>
                            <td>@downloadStatus</td>
                        </tr>
                        <tr>
                            <th>Duplicate Request Status</th>
                            <td>@duplicateStatus</td>
                        </tr>
                        <tr>
                            <th>Payment Status</th>
                            <td>@paymentStatus</td>
                        </tr>
                        <tr>
                            <th>Duplicate Fee</th>
                            <td>@ViewBag.Fee?.Fee</td>
                        </tr>
                        @if (currentTask != null || duplicateStatus == "Under Review")
                        {
                            <tr>
                                <th>Examination</th>
                                <td>The paid duplicate request is under review by an inspector.</td>
                            </tr>
                        }
                        else if (duplicateStatus == "Rejected")
                        {
                            <tr>
                                <th>Examination</th>
                                <td>The duplicate request was rejected. A fresh payment is required to submit another request.</td>
                            </tr>
                        }
                        else if (duplicateStatus == "Awaiting Payment")
                        {
                            <tr>
                                <th>Examination</th>
                                <td>Payment is still outstanding. The request will only be sent for examination after a successful payment.</td>
                            </tr>
                        }

                        @if (downloadStatus == "Open")
                        {
                            <tr>
                                <th>Action</th>
                                <td>
                                    <a href="/Downloads/CheckDownload?LLBNUM=@ViewBag.AppInfo.LLBNum&DocumentType=License" class="btn btn-primary">
                                        Download Licence
                                    </a>
                                </td>
                            </tr>
                        }
                        else if (currentTask != null || duplicateStatus == "Under Review")
                        {
                            <tr>
                                <th>Action</th>
                                <td>
                                    <span class="btn btn-secondary disabled">Awaiting Examination Outcome</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <th>Action</th>
                                <td>
                                    <a href="/Downloads/DownloadPayment?downloadId=@ViewBag.Download.Id&fee=@ViewBag.Fee.Fee&applicationId=@ViewBag.AppInfo.Id" class="btn btn-primary">
                                        Pay For Duplicate
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>




