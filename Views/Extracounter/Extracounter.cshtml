@using LLB.Models
@using System.Linq

@{
    Layout = "_LayoutMain";

    var application = ViewBag.Appinfo as ApplicationInfo;
    var outlet = ViewBag.Outletinfo as OutletInfo;
    var license = ViewBag.License as LicenseTypes;
    var region = ViewBag.Region as LicenseRegion;
    var record = ViewBag.ApplicationRecord as ExtraCounter;
    var payment = ViewBag.Payment as Payments;
    var attachments = ViewBag.Attachments as IEnumerable<AttachmentInfo> ?? Enumerable.Empty<AttachmentInfo>();
    var allApplications = ViewBag.Applications as IEnumerable<ExtraCounter> ?? Enumerable.Empty<ExtraCounter>();
    var serviceName = ViewBag.ServiceName as string ?? "Permission To Alter";
    var serviceLower = serviceName.ToLowerInvariant();
    var processCode = ViewBag.ProcessCode as string ?? "ECF";
    var isExtraCounter = string.Equals(processCode, "EXC", StringComparison.OrdinalIgnoreCase);
    var actionTitle = isExtraCounter ? "Initialise" : "Submit";
    var actionLower = isExtraCounter ? "initialise" : "submit";
    var actionPast = isExtraCounter ? "initialised" : "submitted";
    var actionPastTitle = isExtraCounter ? "Initialised" : "Submitted";

    var canUploadAttachments = ViewBag.CanUploadAttachments is bool upload && upload;
    var attachmentsComplete = ViewBag.AttachmentsComplete is bool complete && complete;
    var requiresAlterationDetails = ViewBag.RequiresAlterationDetails is bool requiresDetails && requiresDetails;
    var alterationDetailsComplete = ViewBag.AlterationDetailsComplete is bool detailsComplete && detailsComplete;
    var canSubmit = ViewBag.CanSubmit is bool submit && submit;
    var canMakePayment = ViewBag.CanMakePayment is bool pay && pay;
    var canContinue = ViewBag.CanContinue is bool cont && cont;
    var awaitingSecretary = ViewBag.AwaitingSecretary is bool awaiting && awaiting;
    var paymentReceived = ViewBag.PaymentReceived is bool received && received;
    var fee = ViewBag.TotalFee is double totalFee ? totalFee : record?.PaidFee ?? 0;
    var updatedText = record == null ? "N/A" : record.DateUpdated.ToString("dd MMM yyyy HH:mm");

    Func<string?, string> statusBadgeClass = status => status?.Trim().ToLowerInvariant() switch
    {
        "approved" => "bg-success",
        "rejected" => "bg-danger",
        "awaiting approval" => "bg-info text-dark",
        "submitted" => "bg-primary",
        "inprogress" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    Func<string?, string> paymentBadgeClass = status => status?.Trim().ToLowerInvariant() switch
    {
        "paid" => "bg-success",
        "awaiting delivery" => "bg-warning text-dark",
        "sent" => "bg-warning text-dark",
        "not paid" => "bg-secondary",
        _ => "bg-secondary"
    };

    Func<string?, string> displayStatus = status =>
        isExtraCounter && string.Equals(status, "submitted", StringComparison.OrdinalIgnoreCase)
            ? "Initialised"
            : status ?? "Unknown";
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h5 class="card-title mb-1">@serviceName Application</h5>
            <p class="text-muted mb-0">Attach the required approval documents, @actionLower the application, complete payment, and continue to secretary review.</p>
        </div>
        @if (record != null)
        {
            <span class="badge rounded-pill @statusBadgeClass(record.Status)">
                @displayStatus(record.Status)
            </span>
        }
    </div>
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                    <h6 class="text-uppercase text-muted mb-3">Application Information</h6>
                    <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                        <span class="text-muted">Reference</span>
                        <span class="fw-semibold text-end">@(record?.Reference ?? "Pending")</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                        <span class="text-muted">Trading Name</span>
                        <span class="fw-semibold text-end">@(outlet?.TradingName ?? "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                        <span class="text-muted">LLB Number</span>
                        <span class="fw-semibold text-end">@(application?.LLBNum ?? "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                        <span class="text-muted">Licence</span>
                        <span class="fw-semibold text-end">@(license?.LicenseName ?? "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3 py-2">
                        <span class="text-muted">Region</span>
                        <span class="fw-semibold text-end">@(region?.RegionName ?? "N/A")</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                    <h6 class="text-uppercase text-muted mb-3">Processing Status</h6>
                    <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                        <span class="text-muted">Change Status</span>
                        <span class="badge rounded-pill @statusBadgeClass(record?.Status)">@displayStatus(record?.Status)</span>
                    </div>
                    <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                        <span class="text-muted">Payment Status</span>
                        <span class="badge rounded-pill @paymentBadgeClass(payment?.PaymentStatus ?? payment?.Status ?? record?.PaymentStatus)">
                            @(payment?.PaymentStatus ?? payment?.Status ?? record?.PaymentStatus ?? "Not Paid")
                        </span>
                    </div>
                    <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                        <span class="text-muted">Fee</span>
                        <span class="fw-semibold text-end">@fee.ToString("N2")</span>
                    </div>
                    @if (!requiresAlterationDetails)
                    {
                        <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                            <span class="text-muted">Attachments Complete</span>
                            <span class="fw-semibold text-end">@(attachmentsComplete ? "Yes" : "No")</span>
                        </div>
                    }
                    @if (requiresAlterationDetails)
                    {
                        <div class="d-flex justify-content-between gap-3 border-bottom py-2">
                            <span class="text-muted">Alteration Details Complete</span>
                            <span class="fw-semibold text-end">@(alterationDetailsComplete ? "Yes" : "No")</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between gap-3 py-2">
                        <span class="text-muted">Last Updated</span>
                        <span class="fw-semibold text-end">@updatedText</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (requiresAlterationDetails)
{
    var planUploaded = !string.IsNullOrWhiteSpace(record?.NewPlanPath);
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-1">Alteration Details</h5>
            <p class="text-muted mb-0">Attach the alteration plan and enter the reason for the alterations before submitting.</p>
        </div>
        <div class="card-body">
            <form method="post" enctype="multipart/form-data" action="/Extracounter/SavePermissionToAlterDetails">
                <input type="hidden" name="applicationId" value="@application?.Id" />
                <input type="hidden" name="ecId" value="@record?.Id" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Alteration Plan</label>
                        @if (planUploaded)
                        {
                            <div class="mb-2">
                                <a href="~/@record?.NewPlanPath" target="_blank">View Current Plan</a>
                            </div>
                        }
                        @if (canUploadAttachments)
                        {
                            <input type="file" name="planFile" class="form-control" required="@(!planUploaded)" />
                        }
                        else if (!planUploaded)
                        {
                            <span class="text-danger">No plan uploaded</span>
                        }
                    </div>
                    <div class="col-md-6">
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Reason For Alterations</label>
                        <textarea name="alterationReason" class="form-control" rows="5" required readonly="@(!canUploadAttachments)">@(record?.ExtracounterReason ?? string.Empty)</textarea>
                    </div>
                </div>
                @if (canUploadAttachments)
                {
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Save Alteration Details</button>
                    </div>
                }
            </form>
        </div>
    </div>
}

@if (!requiresAlterationDetails)
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-1">Required Attachments</h5>
            <p class="text-muted mb-0">Upload each document individually. The @actionLower button only appears after all required documents are uploaded.</p>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Document</th>
                            <th>Status</th>
                            <th>File</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attachment in attachments)
                        {
                            var uploaded = !string.IsNullOrWhiteSpace(attachment.DocumentLocation);
                            <tr>
                                <td class="fw-semibold">@attachment.DocumentTitle</td>
                                <td>
                                    <span class="badge rounded-pill @(uploaded ? "bg-success" : "bg-secondary")">
                                        @(uploaded ? "Uploaded" : "Pending")
                                    </span>
                                </td>
                                <td>
                                    @if (uploaded)
                                    {
                                        <a href="~/@attachment.DocumentLocation" target="_blank">View Attachment</a>
                                    }
                                    else if (canUploadAttachments)
                                    {
                                        <form method="post" enctype="multipart/form-data" action="/Extracounter/UploadPermissionToAlterAttachment" class="d-flex flex-column flex-md-row gap-2">
                                            <input type="hidden" name="attachmentId" value="@attachment.Id" />
                                            <input type="hidden" name="applicationId" value="@application?.Id" />
                                            <input type="hidden" name="ecId" value="@record?.Id" />
                                            <input type="file" name="file" class="form-control" required />
                                            <button type="submit" class="btn btn-primary btn-sm">Upload</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No file uploaded</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (uploaded && canUploadAttachments)
                                    {
                                        <a href="/Extracounter/RemovePermissionToAlterAttachment?attachmentId=@attachment.Id&applicationId=@application?.Id&ecId=@record?.Id"
                                           class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Remove this attachment?');">
                                            Remove
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-1">Next Step</h5>
        <p class="text-muted mb-0">The workflow is @(requiresAlterationDetails ? "alteration plan and reason" : "attachments"), @actionLower, payment, then continue to secretary.</p>
    </div>
    <div class="card-body">
        @if (record != null && string.Equals(record.Status, "Approved", StringComparison.OrdinalIgnoreCase))
        {
            <div class="alert alert-success mb-3">This @serviceLower application has been approved by the secretary.</div>
        }
        else if (record != null && string.Equals(record.Status, "Rejected", StringComparison.OrdinalIgnoreCase))
        {
            <div class="alert alert-danger mb-3">This @serviceLower application has been rejected.</div>
        }
        else if (awaitingSecretary)
        {
            <div class="alert alert-info mb-3">The application has been assigned to the secretary and is now waiting for approval.</div>
        }
        else if (canContinue)
        {
            <div class="alert alert-success mb-3">Payment was received successfully. Click continue to send the application to the secretary.</div>
        }
        else if (canMakePayment)
        {
            <div class="alert alert-primary mb-3">The application has been @actionPast. Complete payment to continue.</div>
        }
        else if (record != null && string.Equals(record.Status, "submitted", StringComparison.OrdinalIgnoreCase) && !paymentReceived)
        {
            <div class="alert alert-warning mb-3">The application is @actionPast and waiting for payment confirmation.</div>
        }
        else if (record != null && string.Equals(record.Status, "inprogress", StringComparison.OrdinalIgnoreCase))
        {
            @if (requiresAlterationDetails && !alterationDetailsComplete)
            {
                <div class="alert alert-warning mb-3">Attach the alteration plan and enter the reason for the alterations first. The @actionLower button will appear once those details are complete.</div>
            }
            else
            {
                <div class="alert alert-warning mb-3">Upload every required attachment first. The @actionLower button will appear once the checklist is complete.</div>
            }
        }

        <div class="d-flex flex-wrap gap-2">
            @if (canSubmit && record != null)
            {
                <form method="post" action="/Extracounter/SubmitPermissionToAlter" class="mb-0">
                    <input type="hidden" name="ecId" value="@record.Id" />
                    <button type="submit" class="btn btn-primary">@actionTitle Application</button>
                </form>
            }

            @if (canMakePayment && record != null)
            {
                <a class="btn btn-success" href="/Extracounter/PermissionToAlterPayment?id=@application?.Id&process=@processCode&ecId=@record.Id">
                    Make Payment
                </a>
            }

            @if (canContinue && record != null)
            {
                <form method="post" action="/Extracounter/ContinuePermissionToAlter" class="mb-0">
                    <input type="hidden" name="ecId" value="@record.Id" />
                    <button type="submit" class="btn btn-success">Continue</button>
                </form>
            }

            <a class="btn btn-outline-secondary" href="/Home/ExtraCounterListings">View All Permission To Alter / Extra Counter Applications</a>
        </div>
    </div>
</div>

@if (allApplications.Count() > 1)
{
    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-1">Application History</h5>
            <p class="text-muted mb-0">Other @serviceLower applications @actionPast for this licence.</p>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>@actionPastTitle</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in allApplications.Where(item => item.Id != record?.Id))
                        {
                            <tr>
                                <td class="fw-semibold">@item.Reference</td>
                                <td>@item.DateAdded.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge rounded-pill @statusBadgeClass(item.Status)">@displayStatus(item.Status)</span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @paymentBadgeClass(item.PaymentStatus)">@item.PaymentStatus</span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="/Extracounter/Extracounter?id=@application?.Id&process=@processCode&ecId=@item.Id">
                                        Open
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
