@using System.Globalization
@using System.Linq
@model LLB.Models.ViewModel.ManagerChangePageViewModel

@{
    Layout = "_LayoutMain";

    var applicationId = Model.Application?.Id ?? string.Empty;
    var changeId = Model.ChangeApplication?.Id ?? string.Empty;
    var currentStatus = Model.ChangeApplication?.Status ?? "Not started";
    var paymentStatus = Model.Payment?.PaymentStatus ?? Model.Payment?.Status ?? Model.ChangeApplication?.PaymentStatus ?? "Not Paid";
    var paynowReference = Model.Payment?.PaynowRef ?? "N/A";
    var paymentReceived = string.Equals(paymentStatus, "Paid", StringComparison.OrdinalIgnoreCase);
    var noPaymentRequired = !Model.PaymentRequired
        && !string.Equals(currentStatus, "inprogress", StringComparison.OrdinalIgnoreCase);
    var applicationStatusClass = currentStatus.Trim().ToLowerInvariant() switch
    {
        "approved" => "bg-success",
        "submitted" => "bg-primary",
        "awaiting payment" => "bg-warning text-dark",
        "rejected" => "bg-danger",
        "inprogress" => "bg-info text-dark",
        _ => "bg-secondary"
    };
    var paymentStatusClass = paymentStatus.Trim().ToLowerInvariant() switch
    {
        "paid" => "bg-success",
        "not paid" => "bg-warning text-dark",
        "not required" => "bg-info text-dark",
        "cancelled" => "bg-secondary",
        "rejected" => "bg-danger",
        "expired" => "bg-dark",
        _ => "bg-primary"
    };
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="card mb-4">
    <div class="card-header d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
        <div>
            <h5 class="card-title mb-1">Manager Change Application For @Model.Outlet?.TradingName</h5>
            <p class="text-muted mb-0">Draft your manager changes, submit them for payment, and continue to the secretary after payment confirmation.</p>
        </div>
        @if (Model.ChangeApplication != null)
        {
            <span class="badge bg-light text-dark border">@Model.ChangeApplication.Reference</span>
        }
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="card h-100 border">
                    <div class="card-header bg-light">
                        <h6 class="card-title mb-0">Application Info</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Outlet Name</span>
                            <span class="fw-semibold text-end">@Model.Outlet?.TradingName</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Licence</span>
                            <span class="fw-semibold text-end">@Model.License?.LicenseName</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Region</span>
                            <span class="fw-semibold text-end">@Model.Region?.RegionName</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Application Ref</span>
                            <span class="fw-semibold text-end">@Model.Application?.RefNum</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Initiated By</span>
                            <span class="fw-semibold text-end">@Model.InitiatedByUserName</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2">
                            <span class="text-muted small text-uppercase fw-semibold">Last Updated</span>
                            <span class="fw-semibold text-end">@(Model.ChangeApplication?.DateUpdated ?? "N/A")</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border">
                    <div class="card-header bg-light">
                        <h6 class="card-title mb-0">Change Summary</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Change Status</span>
                            <span class="badge rounded-pill @applicationStatusClass text-wrap text-end px-3 py-2">@currentStatus</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">New Managers</span>
                            <span class="fw-semibold text-end">@Model.NewManagersCount</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Fee Per Manager</span>
                            <span class="fw-semibold text-end">@Model.FeePerManager.ToString("0.00", CultureInfo.InvariantCulture)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Total Fee</span>
                            <span class="fw-semibold text-end">@Model.TotalFee.ToString("0.00", CultureInfo.InvariantCulture)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2 border-bottom">
                            <span class="text-muted small text-uppercase fw-semibold">Payment Status</span>
                            <span class="badge rounded-pill @paymentStatusClass text-wrap text-end px-3 py-2">@paymentStatus</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center gap-3 px-2 py-2">
                            <span class="text-muted small text-uppercase fw-semibold">Paynow Ref</span>
                            <span class="fw-semibold text-end">@paynowReference</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.CanEditDraft)
{
    <div class="alert alert-info">
        This draft is open for changes. Add new managers or change existing manager statuses before submitting the application for payment.
    </div>
}
else if (string.Equals(currentStatus, "awaiting payment", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-warning">
        This application has been submitted for payment. The draft is now read-only.
    </div>
}
else if (string.Equals(currentStatus, "submitted", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-primary">
        This manager change application has already been sent to the secretary and is awaiting review.
    </div>
}
else if (string.Equals(currentStatus, "Approved", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-success">
        This manager change application has been approved. The active manager list now reflects the approved changes.
    </div>
}
else if (string.Equals(currentStatus, "Rejected", StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-danger">
        This manager change application was rejected. Any draft-only changes were reverted.
    </div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Managers</h5>
        @if (Model.CanEditDraft)
        {
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addManagerModal">
                <i class="bi bi-plus-circle me-2"></i>Add Manager
            </button>
        }
    </div>
    <div class="card-body">
        <ul class="nav nav-tabs" id="managerTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="managers-tab" data-bs-toggle="tab" data-bs-target="#managers-pane" type="button" role="tab">
                    Active Managers
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="changes-tab" data-bs-toggle="tab" data-bs-target="#changes-pane" type="button" role="tab">
                    Changes
                </button>
            </li>
        </ul>

        <div class="tab-content mt-3">
            <div class="tab-pane fade show active" id="managers-pane" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Surname</th>
                                <th>National ID</th>
                                <th>Address</th>
                                <th>Status</th>
                                <th>Effective Date</th>
                                <th>Dismissal Date</th>
                                <th>Documents</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Managers.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">No active managers are currently captured for this licence.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var manager in Model.Managers)
                                {
                                    <tr>
                                        <td class="fw-semibold">@manager.Name</td>
                                        <td>@manager.Surname</td>
                                        <td>@manager.NationalId</td>
                                        <td>@manager.Address</td>
                                        <td>
                                            <span class="badge bg-light text-dark border">@manager.DisplayStatus</span>
                                        </td>
                                        <td>@(manager.EffectiveDate == DateTime.MinValue ? "N/A" : manager.EffectiveDate.ToString("yyyy-MM-dd"))</td>
                                        <td>@(manager.DissmisalDate == DateTime.MinValue ? "N/A" : manager.DissmisalDate.ToString("yyyy-MM-dd"))</td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-2">
                                                @if (!string.IsNullOrWhiteSpace(manager.Attachment))
                                                {
                                                    <a class="btn btn-sm btn-outline-secondary" target="_blank" href="@Url.Content($"~/{manager.Attachment}")">ID</a>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(manager.Fingerprints))
                                                {
                                                    <a class="btn btn-sm btn-outline-info" target="_blank" href="@Url.Content($"~/{manager.Fingerprints}")">Fingerprints</a>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(manager.Form55))
                                                {
                                                    <a class="btn btn-sm btn-outline-primary" target="_blank" href="@Url.Content($"~/{manager.Form55}")">Form 55</a>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            @if (manager.CanEditStatus)
                                            {
                                                <button
                                                    type="button"
                                                    class="btn btn-sm btn-warning js-edit-status"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editStatusModal"
                                                    data-id="@manager.Id"
                                                    data-name="@manager.Name"
                                                    data-surname="@manager.Surname"
                                                    data-nationalid="@manager.NationalId"
                                                    data-address="@manager.Address"
                                                    data-status="@manager.Status">
                                                    Edit
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No action</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="changes-pane" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Surname</th>
                                <th>National ID</th>
                                <th>Address</th>
                                <th>Status</th>
                                <th>Documents</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Changes.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">No manager changes have been captured for this application yet.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var manager in Model.Changes)
                                {
                                    <tr>
                                        <td class="fw-semibold">@manager.Name</td>
                                        <td>@manager.Surname</td>
                                        <td>@manager.NationalId</td>
                                        <td>@manager.Address</td>
                                        <td>
                                            <span class="badge bg-light text-dark border">@manager.DisplayStatus</span>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-2">
                                                @if (!string.IsNullOrWhiteSpace(manager.Attachment))
                                                {
                                                    <a class="btn btn-sm btn-outline-secondary" target="_blank" href="@Url.Content($"~/{manager.Attachment}")">ID</a>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(manager.Fingerprints))
                                                {
                                                    <a class="btn btn-sm btn-outline-info" target="_blank" href="@Url.Content($"~/{manager.Fingerprints}")">Fingerprints</a>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(manager.Form55))
                                                {
                                                    <a class="btn btn-sm btn-outline-primary" target="_blank" href="@Url.Content($"~/{manager.Form55}")">Form 55</a>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                @if (manager.CanEditDetails)
                                                {
                                                    <button
                                                        type="button"
                                                        class="btn btn-sm btn-warning js-edit-draft-manager"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editDraftManagerModal"
                                                        data-id="@manager.Id"
                                                        data-name="@manager.Name"
                                                        data-surname="@manager.Surname"
                                                        data-nationalid="@manager.NationalId"
                                                        data-address="@manager.Address">
                                                        Edit
                                                    </button>
                                                }
                                                @if (manager.CanEditStatus)
                                                {
                                                    <button
                                                        type="button"
                                                        class="btn btn-sm btn-warning js-edit-status"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editStatusModal"
                                                        data-id="@manager.Id"
                                                        data-name="@manager.Name"
                                                        data-surname="@manager.Surname"
                                                        data-nationalid="@manager.NationalId"
                                                        data-address="@manager.Address"
                                                        data-status="@manager.Status">
                                                        Edit
                                                    </button>
                                                }
                                                @if (manager.CanDelete)
                                                {
                                                    <form action="/Managers/DeleteManager" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="managerId" value="@manager.Id" />
                                                        <input type="hidden" name="applicationId" value="@applicationId" />
                                                        <input type="hidden" name="changeId" value="@changeId" />
                                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this draft manager?');">Delete</button>
                                                    </form>
                                                }
                                                @if (!manager.CanEditDetails && !manager.CanDelete)
                                                {
                                                    <span class="text-muted small">No action</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">Submission Steps</h5>
    </div>
    <div class="card-body">
        <div class="d-flex flex-column gap-3">
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 1: Capture Changes</div>
                <div class="text-muted">Use the tabs above to add new managers or update current manager statuses for this draft.</div>
            </div>
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 2: Submit Draft For Payment</div>
                <div class="text-muted mb-3">The manager change fee is charged per newly added manager. Status-only changes remain in the application but do not increase the fee.</div>
                @if (Model.CanSubmitDraft)
                {
                    <form action="/Managers/SubmitChangeApplication" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="applicationId" value="@applicationId" />
                        <input type="hidden" name="changeId" value="@changeId" />
                        <button class="btn btn-primary" type="submit">Submit Application</button>
                    </form>
                }
                else if (!Model.HasChanges)
                {
                    <span class="badge bg-light text-dark border">No changes captured yet</span>
                }
                else
                {
                    <span class="badge bg-secondary">Already submitted for payment</span>
                }
            </div>
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 3: Payment</div>
                <div class="text-muted mb-3">Each change-manager application keeps its own payment record. Another draft is not opened while this one is still in progress.</div>
                @if (noPaymentRequired)
                {
                    <span class="badge bg-success">No payment required</span>
                }
                else if (Model.CanMakePayment)
                {
                    <a class="btn btn-primary" href="/Managers/ManagerChangePayment?id=@applicationId&changeId=@changeId&process=@Model.Process">Make Payment</a>
                }
                else if (paymentReceived)
                {
                    <span class="badge bg-success">Payment received</span>
                }
                else
                {
                    <span class="badge bg-light text-dark border">Payment becomes available after draft submission</span>
                }
            </div>
            <div class="border rounded p-3">
                <div class="fw-semibold mb-1">Step 4: Continue To Secretary</div>
                <div class="text-muted mb-3">After payment is confirmed, continue to send this manager change application to the secretary for approval.</div>
                @if (Model.CanContinue)
                {
                    <form action="/Managers/ContinueManagerChange" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="applicationId" value="@applicationId" />
                        <input type="hidden" name="changeId" value="@changeId" />
                        <button class="btn btn-success" type="submit">Continue</button>
                    </form>
                }
                else if (string.Equals(currentStatus, "submitted", StringComparison.OrdinalIgnoreCase))
                {
                    <span class="badge bg-primary">Already sent to secretary</span>
                }
                else
                {
                    <span class="badge bg-light text-dark border">Payment confirmation is required before continuing</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addManagerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Manager</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/Managers/AddManager" enctype="multipart/form-data" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="applicationId" value="@applicationId" />
                    <input type="hidden" name="changeId" value="@changeId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" name="name" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Surname</label>
                            <input type="text" name="surname" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">National ID</label>
                            <input type="text" name="nationalId" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <textarea name="address" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">National ID Copy</label>
                            <input type="file" name="file" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Fingerprints</label>
                            <input type="file" name="fileb" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Form 55</label>
                            <input type="file" name="form55" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save Manager</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editDraftManagerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Draft Manager</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/Managers/UpdateDraftManager" enctype="multipart/form-data" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="applicationId" value="@applicationId" />
                    <input type="hidden" name="changeId" value="@changeId" />
                    <input type="hidden" name="managerId" id="editDraftManagerId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" name="name" id="editDraftManagerName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Surname</label>
                            <input type="text" name="surname" id="editDraftManagerSurname" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">National ID</label>
                            <input type="text" name="nationalId" id="editDraftManagerNationalId" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <textarea name="address" id="editDraftManagerAddress" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Replace National ID Copy</label>
                            <input type="file" name="file" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Replace Fingerprints</label>
                            <input type="file" name="fileb" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Replace Form 55</label>
                            <input type="file" name="form55" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Manager</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/Managers/UpdateManagerStatus" enctype="multipart/form-data" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="applicationId" value="@applicationId" />
                    <input type="hidden" name="changeId" value="@changeId" />
                    <input type="hidden" name="managerId" id="editStatusManagerId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input type="text" name="name" id="editStatusManagerName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Surname</label>
                            <input type="text" name="surname" id="editStatusManagerSurname" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">National ID</label>
                            <input type="text" name="nationalId" id="editStatusManagerNationalId" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <textarea name="address" id="editStatusManagerAddress" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Replace National ID Copy</label>
                            <input type="file" name="file" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Replace Fingerprints</label>
                            <input type="file" name="fileb" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Replace Form 55</label>
                            <input type="file" name="form55" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="requestedStatus" id="editStatusRequestedStatus">
                                <option value="active">Active</option>
                                <option value="resigned">Resigned</option>
                                <option value="deceased">Deceased</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".js-edit-draft-manager").forEach(function (button) {
        button.addEventListener("click", function () {
            document.getElementById("editDraftManagerId").value = button.dataset.id || "";
            document.getElementById("editDraftManagerName").value = button.dataset.name || "";
            document.getElementById("editDraftManagerSurname").value = button.dataset.surname || "";
            document.getElementById("editDraftManagerNationalId").value = button.dataset.nationalid || "";
            document.getElementById("editDraftManagerAddress").value = button.dataset.address || "";
        });
    });

    document.querySelectorAll(".js-edit-status").forEach(function (button) {
        button.addEventListener("click", function () {
            document.getElementById("editStatusManagerId").value = button.dataset.id || "";
            document.getElementById("editStatusManagerName").value = button.dataset.name || "";
            document.getElementById("editStatusManagerSurname").value = button.dataset.surname || "";
            document.getElementById("editStatusManagerNationalId").value = button.dataset.nationalid || "";
            document.getElementById("editStatusManagerAddress").value = button.dataset.address || "";

            var normalizedStatus = (button.dataset.status || "").toLowerCase().trim();
            if (normalizedStatus === "pending-resigned") {
                normalizedStatus = "resigned";
            }
            if (normalizedStatus === "pending-deceased") {
                normalizedStatus = "deceased";
            }
            if (normalizedStatus !== "resigned" && normalizedStatus !== "deceased") {
                normalizedStatus = "active";
            }

            document.getElementById("editStatusRequestedStatus").value = normalizedStatus;
        });
    });
});
</script>
