@model LLB.Models.ViewModel.ExtendedHoursCertificateVerificationViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Extended Hours Certificate Verification";
}

<section class="section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 p-lg-5">
                        <div class="text-center mb-4">
                            <img src="~/front/img/IMG/Coat_of_arms_of_ZimbabweB.png" alt="Zimbabwe Coat of Arms" style="height: 88px;" />
                            <h2 class="mt-3 mb-2">Extended Hours Certificate Verification</h2>
                            <p class="text-muted mb-0">Liquor Licensing Board certificate status and approved operating details.</p>
                        </div>

                        <div class="alert @(Model.IsValid ? "alert-success" : "alert-warning") border-0" role="alert">
                            <strong>@(Model.IsValid ? "Certificate Verified" : "Verification Warning")</strong><br />
                            @Model.Message
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Certificate Reference</small>
                                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.CertificateReference) ? Model.CertificateReference : "N/A")</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Status</small>
                                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.Status) ? Model.Status : "Unknown")</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Trading Name</small>
                                    <div class="fw-semibold">@Model.TradingName</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Business Name</small>
                                    <div class="fw-semibold">@Model.BusinessName</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">LLB Number</small>
                                    <div class="fw-semibold">@Model.LLBNumber</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Licence Type</small>
                                    <div class="fw-semibold">@Model.LicenseName</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Region</small>
                                    <div class="fw-semibold">@Model.RegionName</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Council</small>
                                    <div class="fw-semibold">@Model.Council</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Extended Hours Date</small>
                                    <div class="fw-semibold">@(Model.ExtendedHoursDate?.ToString("dddd, dd MMMM yyyy") ?? "N/A")</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Approved On</small>
                                    <div class="fw-semibold">@(Model.ApprovedOn?.ToString("dd MMMM yyyy") ?? "N/A")</div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="border rounded-3 p-3">
                                    <small class="text-uppercase text-muted d-block mb-1">Address / Location</small>
                                    <div class="fw-semibold">@Model.Address</div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="border rounded-3 p-3">
                                    <small class="text-uppercase text-muted d-block mb-1">Justification</small>
                                    <div class="fw-semibold">@Model.Justification</div>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <a class="btn btn-outline-primary" href="/">Return To Home</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
