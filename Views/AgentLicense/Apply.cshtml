    @if (canMakePayment)
    {
        <div class="modal fade" id="agentLicenseCurrencyPaymentModal" tabindex="-1" aria-labelledby="agentLicenseCurrencyPaymentModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <form method="get" action="/AgentLicense/Payment" class="modal-content" id="agentLicenseCurrencyPaymentForm">
                    <input type="hidden" name="id" value="@currentAgentApplication.Id" />
                    <div class="modal-header">
                        <h5 class="modal-title" id="agentLicenseCurrencyPaymentModalLabel">Select Payment Currency</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" data-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="llb-payment-price mb-3">
                            <div class="d-flex justify-content-between gap-3">
                                <span class="text-muted">USD Amount</span>
                                <strong>@FormatPaymentAmount("USD", agentPaymentUsdAmount)</strong>
                            </div>
                            <div class="d-flex justify-content-between gap-3 mt-2">
                                <span class="text-muted">ZWG Amount</span>
                                <strong>@(latestZwgExchangeRate > 0 ? FormatPaymentAmount("ZWG", agentPaymentZwgAmount) : "Rate not configured")</strong>
                            </div>
                            <div class="small text-muted mt-2">
                                @(latestZwgExchangeRate > 0
                                    ? $"Exchange rate: 1 USD = {latestZwgExchangeRate:N4} ZWG"
                                    : "No saved USD/ZWG exchange rate is available.")
                            </div>
                        </div>

                        <div class="d-grid gap-3">
                            <label class="llb-currency-option active" data-agent-license-currency-option="USD">
                                <span class="d-flex align-items-center justify-content-between gap-3">
                                    <span class="d-flex align-items-center gap-3">
                                        <input class="form-check-input m-0" type="radio" name="currency" value="USD" checked>
                                        <span>
                                            <span class="fw-semibold d-block">USD</span>
                                            <span class="text-muted small">Pay using the USD price configured in the system.</span>
                                        </span>
                                    </span>
                                    <span class="fw-semibold text-nowrap">@FormatPaymentAmount("USD", agentPaymentUsdAmount)</span>
                                </span>
                            </label>

                            <label class="llb-currency-option" data-agent-license-currency-option="ZWG">
                                <span class="d-flex align-items-center justify-content-between gap-3">
                                    <span class="d-flex align-items-center gap-3">
                                        <input class="form-check-input m-0" type="radio" name="currency" value="ZWG">
                                        <span>
                                            <span class="fw-semibold d-block">ZWG</span>
                                            <span class="text-muted small">Pay using the latest saved USD/ZWG exchange rate.</span>
                                        </span>
                                    </span>
                                    <span class="fw-semibold text-nowrap">@(latestZwgExchangeRate > 0 ? FormatPaymentAmount("ZWG", agentPaymentZwgAmount) : "Rate not configured")</span>
                                </span>
                            </label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Make Payment</button>
                    </div>
                </form>
            </div>
        </div>
    }
}

<script>
    (function () {
        const nameInput = document.getElementById("agentEditName");
        const surnameInput = document.getElementById("agentEditSurname");
        const businessNameInput = document.getElementById("agentEditBusinessName");
        if (!nameInput || !surnameInput || !businessNameInput) {
            return;
        }

        function syncBusinessName() {
            businessNameInput.value = [nameInput.value, surnameInput.value]
                .map(function (value) { return value.trim(); })
                .filter(Boolean)
                .join(" ");
        }

        nameInput.addEventListener("input", syncBusinessName);
        surnameInput.addEventListener("input", syncBusinessName);
    })();
</script>

@section Scripts {
    <script>
        (function () {
            const modalElement = document.getElementById("agentLicenseCurrencyPaymentModal");
            const modalButton = document.querySelector('[data-bs-target="#agentLicenseCurrencyPaymentModal"], [data-target="#agentLicenseCurrencyPaymentModal"]');
            const options = Array.from(document.querySelectorAll("[data-agent-license-currency-option]"));

            options.forEach(function (option) {
                option.addEventListener("click", function () {
                    const currency = option.getAttribute("data-agent-license-currency-option");
                    const input = option.querySelector('input[type="radio"]');
                    if (input) {
                        input.checked = true;
                    }

                    options.forEach(function (item) {
                        item.classList.toggle("active", item.getAttribute("data-agent-license-currency-option") === currency);
                    });
                });
            });

            if (modalElement && modalButton) {
                modalButton.addEventListener("click", function () {
                    if (window.bootstrap && window.bootstrap.Modal) {
                        window.bootstrap.Modal.getOrCreateInstance(modalElement).show();
                        return;
                    }

                    if (window.jQuery) {
                        window.jQuery(modalElement).modal("show");
                        return;
                    }

                    modalElement.classList.add("show");
                    modalElement.style.display = "block";
                    modalElement.removeAttribute("aria-hidden");
                });
            }
        })();
    </script>
}
