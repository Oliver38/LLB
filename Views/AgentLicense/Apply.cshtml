@using LLB.Helpers
@using LLB.Models

@{
    Layout = "_LayoutMain";
    ViewData["Title"] = "Agent License";

    var user = ViewBag.User as ApplicationUser;
    var wholesaleApplication = ViewBag.WholesaleApplication as ApplicationInfo;
    var agentApplication = ViewBag.AgentApplication as ApplicationInfo;
    var wholesaleLicense = ViewBag.WholesaleLicense as LicenseTypes;
    var agentLicense = ViewBag.AgentLicense as LicenseTypes;
    var wholesaleOutlet = ViewBag.WholesaleOutlet as OutletInfo;
    var tieAffidavit = ViewBag.TieAffidavit as AttachmentInfo;
    var wholesaleLicenseAttachment = ViewBag.WholesaleLicenseAttachment as AttachmentInfo;
    var payment = ViewBag.Payment as Payments;
    var searchValue = ViewBag.SearchValue as string ?? string.Empty;
    var fromPostFormation = ViewBag.FromPostFormation is bool openedFromPostFormation && openedFromPostFormation;

    string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "N/A" : value;
    }

    string StatusBadgeClass(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "approved" => "bg-success",
            "paid" => "bg-success",
            "awaiting approval" => "bg-info text-dark",
            "awaiting verification" => "bg-info text-dark",
            "awaiting payment" => "bg-warning text-dark",
            "payment not required" => "bg-info text-dark",
            "rejected" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    string PaymentBadgeClass(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "paid" => "bg-success",
            "awaiting delivery" => "bg-warning text-dark",
            "sent" => "bg-warning text-dark",
            "created" => "bg-warning text-dark",
            "not paid" => "bg-secondary",
            "not required" => "bg-info text-dark",
            _ => "bg-secondary"
        };
    }

    var nameValue = agentApplication?.PlaceOfBirth ?? user?.Name ?? string.Empty;
    var surnameValue = agentApplication?.PlaceOfEntry ?? user?.LastName ?? string.Empty;
    var dobValue = agentApplication?.DateofEntryIntoZimbabwe ?? user?.DOB ?? string.Empty;
    var genderValue = agentApplication?.RenewalStatus ?? user?.Gender ?? string.Empty;
    var nationalityValue = agentApplication?.OperationAddress ?? user?.Nationality ?? string.Empty;
    var idPassValue = agentApplication?.IdPass ?? user?.NatID ?? string.Empty;
    var businessNameValue = agentApplication?.BusinessName ?? $"{user?.Name} {user?.LastName}".Trim();
    var agentStatus = agentApplication?.Status?.Trim().ToLowerInvariant();
    var paymentStatus = payment?.PaymentStatus ?? payment?.Status ?? agentApplication?.PaymentStatus ?? "Not Paid";
    var paymentRequired = (agentApplication?.PaymentFee ?? 0) > 0;
    var paymentComplete = !paymentRequired
        || string.Equals(payment?.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase)
        || string.Equals(payment?.Status, "Paid", StringComparison.OrdinalIgnoreCase)
        || string.Equals(agentApplication?.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase);
    var titleValue = agentApplication?.Title ?? string.Empty;
    var isPaymentStage = agentStatus == "awaiting payment"
        || agentStatus == "payment pending"
        || agentStatus == "paid"
        || agentStatus == "payment not required";
    var hasActivePayment = payment != null
        && !paymentComplete
        && !string.Equals(payment.PaymentStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.Status, "Cancelled", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.PaymentStatus, "Canceled", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.Status, "Canceled", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.PaymentStatus, "Rejected", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.Status, "Rejected", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.PaymentStatus, "Expired", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.Status, "Expired", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.PaymentStatus, "Created", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.Status, "Created", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.PaymentStatus, "Awaiting Delivery", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment.Status, "Awaiting Delivery", StringComparison.OrdinalIgnoreCase);
    var allRequiredDocumentsUploaded = agentApplication != null
        && !string.IsNullOrWhiteSpace(agentApplication.IdCopy)
        && !string.IsNullOrWhiteSpace(agentApplication.Fingerprints)
        && !string.IsNullOrWhiteSpace(agentApplication.FormFF)
        && !string.IsNullOrWhiteSpace(tieAffidavit?.DocumentLocation)
        && !string.IsNullOrWhiteSpace(wholesaleLicenseAttachment?.DocumentLocation);
    var canUploadDocuments = agentApplication != null
        && isPaymentStage
        && !hasActivePayment
        && !string.Equals(agentApplication.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment?.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(payment?.Status, "Paid", StringComparison.OrdinalIgnoreCase);
    var canMakePayment = agentApplication != null && isPaymentStage && allRequiredDocumentsUploaded && paymentRequired && !paymentComplete && !hasActivePayment;
    var canContinue = agentApplication != null && isPaymentStage && allRequiredDocumentsUploaded && paymentComplete;
    var canEditSubmittedApplicantDetails = fromPostFormation
        && agentApplication != null
        && isPaymentStage
        && !string.Equals(agentApplication.Status, "approved", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(agentApplication.Status, "rejected", StringComparison.OrdinalIgnoreCase);
    var latestZwgExchangeRate = Convert.ToDouble(ViewBag.LatestZwgExchangeRate ?? 0);
    var agentPaymentUsdAmount = agentApplication?.PaymentFee ?? 0;
    var agentPaymentZwgAmount = latestZwgExchangeRate > 0
        ? agentPaymentUsdAmount * (decimal)latestZwgExchangeRate
        : 0;

    string FormatPaymentAmount(string currency, decimal amount)
    {
        return $"{currency} {amount:N2}";
    }
}

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-1">Wholesale Licence</h5>
        <p class="text-muted mb-0">Enter the LLB number for the wholesale licence the agent is applying under.</p>
    </div>
    <div class="card-body">
        <form method="get" action="/AgentLicense/Apply" class="row g-3 align-items-end">
            <input type="hidden" name="fromPostFormation" value="@fromPostFormation.ToString().ToLowerInvariant()" />
            <div class="col-md-8">
                <label class="form-label" for="llbNumber">Wholesale LLB Number</label>
                <input type="text" id="llbNumber" name="llbNumber" value="@searchValue" class="form-control" required />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">Retrieve Wholesale Licence</button>
            </div>
        </form>
    </div>
</div>

@if (wholesaleApplication != null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="card-title mb-1">Wholesale Licence Details</h5>
                <p class="text-muted mb-0">The agent licence will be linked to this wholesale licence.</p>
            </div>
            <span class="badge rounded-pill bg-dark">@(wholesaleApplication.LLBNum ?? "N/A")</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">Licensee</span>
                        <span class="fw-semibold text-end">@DisplayValue(wholesaleApplication.BusinessName)</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">Licence</span>
                        <span class="fw-semibold text-end">@DisplayValue(wholesaleLicense?.LicenseName)</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted">Trading Name</span>
                        <span class="fw-semibold text-end">@DisplayValue(wholesaleOutlet?.TradingName)</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">Address</span>
                        <span class="fw-semibold text-end">@DisplayValue(wholesaleOutlet?.Address)</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span class="text-muted">Council</span>
                        <span class="fw-semibold text-end">@DisplayValue(wholesaleOutlet?.Council)</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted">City</span>
                        <span class="fw-semibold text-end">@DisplayValue(wholesaleOutlet?.City)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (agentApplication == null)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-1">Agent Information</h5>
                <p class="text-muted mb-0">Review and edit the agent details. Required documents are uploaded one by one after saving.</p>
            </div>
            <div class="card-body">
                <form method="post" action="/AgentLicense/Submit" enctype="multipart/form-data" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="llbNumber" value="@wholesaleApplication.LLBNum" />
                    <input type="hidden" name="fromPostFormation" value="@fromPostFormation.ToString().ToLowerInvariant()" />

                    <div class="col-md-4">
                        <label class="form-label">Title</label>
                        <select name="title" class="form-select" required>
                            <option value="">Select title</option>
                            <option value="Mr" selected="@(string.Equals(titleValue, "Mr", StringComparison.OrdinalIgnoreCase))">Mr</option>
                            <option value="Mrs" selected="@(string.Equals(titleValue, "Mrs", StringComparison.OrdinalIgnoreCase))">Mrs</option>
                            <option value="Miss" selected="@(string.Equals(titleValue, "Miss", StringComparison.OrdinalIgnoreCase))">Miss</option>
                            <option value="Ms" selected="@(string.Equals(titleValue, "Ms", StringComparison.OrdinalIgnoreCase))">Ms</option>
                            <option value="Dr" selected="@(string.Equals(titleValue, "Dr", StringComparison.OrdinalIgnoreCase))">Dr</option>
                            <option value="Prof" selected="@(string.Equals(titleValue, "Prof", StringComparison.OrdinalIgnoreCase))">Prof</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Name</label>
                        <input type="text" name="name" value="@nameValue" class="form-control" id="agentName" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Surname</label>
                        <input type="text" name="surname" value="@surnameValue" class="form-control" id="agentSurname" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">DOB</label>
                        <input type="text" name="dob" value="@dobValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <input type="text" name="gender" value="@genderValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nationality</label>
                        <input type="text" name="nationality" value="@nationalityValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ID or Passport Number</label>
                        <input type="text" name="idPass" value="@idPassValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Applicant Type</label>
                        <input type="text" name="applicantType" value="Individual" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Licensee Name</label>
                        <input type="text" name="businessName" value="@businessNameValue" class="form-control" id="agentBusinessName" readonly required />
                    </div>

                    <div class="col-12 d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Save Agent Information</button>
                    </div>
                </form>
            </div>
        </div>
    }
}

<script>
    (function () {
        const nameInput = document.getElementById("agentName");
        const surnameInput = document.getElementById("agentSurname");
        const businessNameInput = document.getElementById("agentBusinessName");
        if (!nameInput || !surnameInput || !businessNameInput) {
            return;
        }

        function syncBusinessName() {
            businessNameInput.value = [nameInput.value, surnameInput.value]
                .map(function (value) { return value.trim(); })
                .filter(Boolean)
                .join(" ");
        }

        nameInput.addEventListener("input", syncBusinessName);
        surnameInput.addEventListener("input", syncBusinessName);
    })();
</script>

@if (agentApplication != null)
{
    var currentAgentApplication = agentApplication;

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="card-title mb-1">Agent License Application</h5>
                <p class="text-muted mb-0">Submitted agent details and required attachments.</p>
            </div>
            <span class="badge rounded-pill @StatusBadgeClass(currentAgentApplication.Status)">@(currentAgentApplication.Status ?? "Unknown")</span>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small text-uppercase fw-semibold">Payment Fee</div>
                        <div class="fs-6 fw-semibold">@(currentAgentApplication.PaymentFee ?? 0)</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small text-uppercase fw-semibold">Payment Status</div>
                        <span class="badge rounded-pill @PaymentBadgeClass(paymentStatus)">@paymentStatus</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small text-uppercase fw-semibold">Paynow Ref</div>
                        <div class="fw-semibold">@(payment?.PaynowRef ?? "N/A")</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small text-uppercase fw-semibold">Verification</div>
                        <div class="fw-semibold">@(isPaymentStage ? "Not submitted" : "Submitted")</div>
                    </div>
                </div>
            </div>

            @if (isPaymentStage)
            {
                <div class="alert alert-info">
                    @(allRequiredDocumentsUploaded
                        ? "Complete payment, then continue to submit this agent license application for verification."
                        : "Upload all required documents before payment or verification.")
                </div>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    @if (canMakePayment)
                    {
                        <button type="button"
                                class="btn btn-success"
                                data-bs-toggle="modal"
                                data-bs-target="#agentLicenseCurrencyPaymentModal"
                                data-toggle="modal"
                                data-target="#agentLicenseCurrencyPaymentModal"
                                data-allow-multiple-click="true">
                            Make Payment
                        </button>
                    }
                    @if (hasActivePayment && !string.IsNullOrWhiteSpace(payment?.SystemRef))
                    {
                        <a class="btn btn-outline-primary" href="@payment.SystemRef">Resume Payment</a>
                    }
                    @if (canContinue)
                    {
                        <form method="post" action="/AgentLicense/Continue" class="mb-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@currentAgentApplication.Id" />
                            <button type="submit" class="btn btn-primary">Submit For Verification</button>
                        </form>
                    }
                </div>
            }

            @if (canEditSubmittedApplicantDetails)
            {
                <form method="post" action="/AgentLicense/UpdateApplicantDetails" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@currentAgentApplication.Id" />
                    <div class="col-md-6">
                        <label class="form-label">Reference</label>
                        <input type="text" value="@DisplayValue(currentAgentApplication.RefNum)" class="form-control" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Agent Licence</label>
                        <input type="text" value="@DisplayValue(agentLicense?.LicenseName)" class="form-control" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Title</label>
                        <select name="title" class="form-select" required>
                            <option value="">Select title</option>
                            <option value="Mr" selected="@(string.Equals(titleValue, "Mr", StringComparison.OrdinalIgnoreCase))">Mr</option>
                            <option value="Mrs" selected="@(string.Equals(titleValue, "Mrs", StringComparison.OrdinalIgnoreCase))">Mrs</option>
                            <option value="Miss" selected="@(string.Equals(titleValue, "Miss", StringComparison.OrdinalIgnoreCase))">Miss</option>
                            <option value="Ms" selected="@(string.Equals(titleValue, "Ms", StringComparison.OrdinalIgnoreCase))">Ms</option>
                            <option value="Dr" selected="@(string.Equals(titleValue, "Dr", StringComparison.OrdinalIgnoreCase))">Dr</option>
                            <option value="Prof" selected="@(string.Equals(titleValue, "Prof", StringComparison.OrdinalIgnoreCase))">Prof</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Name</label>
                        <input type="text" name="name" value="@nameValue" class="form-control" id="agentEditName" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Surname</label>
                        <input type="text" name="surname" value="@surnameValue" class="form-control" id="agentEditSurname" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">DOB</label>
                        <input type="text" name="dob" value="@dobValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <input type="text" name="gender" value="@genderValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nationality</label>
                        <input type="text" name="nationality" value="@nationalityValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ID or Passport Number</label>
                        <input type="text" name="idPass" value="@idPassValue" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Applicant Type</label>
                        <input type="text" name="applicantType" value="@(string.IsNullOrWhiteSpace(currentAgentApplication.ApplicantType) ? "Individual" : currentAgentApplication.ApplicantType)" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Licensee Name</label>
                        <input type="text" value="@businessNameValue" class="form-control" id="agentEditBusinessName" readonly />
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Save Applicant Details</button>
                    </div>
                </form>
            }
            else
            {
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">Reference</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.RefNum)</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">Title</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.Title)</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">Name</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.PlaceOfBirth)</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">Surname</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.PlaceOfEntry)</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">DOB</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.DateofEntryIntoZimbabwe)</span>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span class="text-muted">Gender</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.RenewalStatus)</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">Nationality</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.OperationAddress)</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">ID or Passport</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.IdPass)</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">Applicant Type</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.ApplicantType)</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span class="text-muted">Licensee Name</span>
                            <span class="fw-semibold text-end">@DisplayValue(currentAgentApplication.BusinessName)</span>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span class="text-muted">Agent Licence</span>
                            <span class="fw-semibold text-end">@DisplayValue(agentLicense?.LicenseName)</span>
                        </div>
                    </div>
                </div>
            }

            @if (isPaymentStage && !allRequiredDocumentsUploaded)
            {
                <div class="alert alert-warning mt-4">
                    Upload each required document before making payment or submitting for verification.
                </div>
            }

            <div class="table-responsive mt-4">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Document</th>
                            <th>Status</th>
                            <th>File</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-semibold">Tie Affidavit</td>
                            <td><span class="badge rounded-pill @(string.IsNullOrWhiteSpace(tieAffidavit?.DocumentLocation) ? "bg-secondary" : "bg-success")">@(string.IsNullOrWhiteSpace(tieAffidavit?.DocumentLocation) ? "Missing" : "Uploaded")</span></td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(tieAffidavit?.DocumentLocation))
                                {
                                    <a href="~/@tieAffidavit.DocumentLocation" target="_blank">View Attachment</a>
                                }
                                else
                                {
                                    <span class="text-muted">Missing</span>
                                }
                            </td>
                            <td>
                                @if (canUploadDocuments)
                                {
                                    <form method="post" action="/AgentLicense/UploadAttachment" enctype="multipart/form-data" class="d-flex flex-column flex-md-row gap-2 mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@currentAgentApplication.Id" />
                                        <input type="hidden" name="documentType" value="tieAffidavit" />
                                        <input type="file" name="file" class="form-control form-control-sm" required />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">@(string.IsNullOrWhiteSpace(tieAffidavit?.DocumentLocation) ? "Upload" : "Replace")</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">Locked</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">Fingerprint</td>
                            <td><span class="badge rounded-pill @(string.IsNullOrWhiteSpace(currentAgentApplication.Fingerprints) ? "bg-secondary" : "bg-success")">@(string.IsNullOrWhiteSpace(currentAgentApplication.Fingerprints) ? "Missing" : "Uploaded")</span></td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(currentAgentApplication.Fingerprints))
                                {
                                    <a href="~/@currentAgentApplication.Fingerprints" target="_blank">View Attachment</a>
                                }
                                else
                                {
                                    <span class="text-muted">Missing</span>
                                }
                            </td>
                            <td>
                                @if (canUploadDocuments)
                                {
                                    <form method="post" action="/AgentLicense/UploadAttachment" enctype="multipart/form-data" class="d-flex flex-column flex-md-row gap-2 mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@currentAgentApplication.Id" />
                                        <input type="hidden" name="documentType" value="fingerprints" />
                                        <input type="file" name="file" class="form-control form-control-sm" required />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">@(string.IsNullOrWhiteSpace(currentAgentApplication.Fingerprints) ? "Upload" : "Replace")</button>
