@{
    var pageTitle = ViewData["Title"]?.ToString();
    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = "Liquor Licensing Board";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@pageTitle - LLB</title>
    <meta name="description" content="Digital services for liquor licence applications, renewals, inspections, and compliance." />

    <link href="~/NiceAdmin/assets/img/favicon.png" rel="icon" />
    <link href="~/NiceAdmin/assets/img/apple-touch-icon.png" rel="apple-touch-icon" />

    <link href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,500,600,700|Nunito:400,600,700,800|Poppins:400,500,600,700" rel="stylesheet" />

    <link href="~/NiceAdmin/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/NiceAdmin/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/NiceAdmin/assets/css/style.css" rel="stylesheet" />
    <link href="~/NiceAdmin/assets/css/llb-theme.css" rel="stylesheet" />
</head>
<body class="llb-public-shell">
    <header class="llb-public-header sticky-top">
        <div class="container-xl py-3">
            <div class="d-flex align-items-center justify-content-between gap-3">
                <a href="/Home/LandingPage" class="d-flex align-items-center text-decoration-none llb-brand">
                    <img src="~/front/img/IMG/Coat_of_arms_of_ZimbabweB.png" alt="LLB" class="llb-brand-logo" />
                    <div>
                        <div class="fw-bold text-dark">Liquor Licensing Board</div>
                        <small class="text-muted">Digital licensing services</small>
                    </div>
                </a>

                <nav class="llb-public-nav d-none d-lg-flex align-items-center gap-2">
                    <a href="/Home/LandingPage#hero" class="text-decoration-none">Home</a>
                    <a href="/Home/LandingPage#about" class="text-decoration-none">About</a>
                    <a href="/Home/LandingPage#services" class="text-decoration-none">Services</a>
                    <a href="/Home/LandingPage#contact" class="text-decoration-none">Contact</a>
                    <a href="/Home/FAQ" class="text-decoration-none">FAQ</a>
                </nav>

                <div class="d-flex align-items-center gap-2">
                    <a href="/Auth/Login" class="btn btn-outline-primary btn-sm">Sign In</a>
                    <a href="/Auth/Register" class="btn btn-primary btn-sm">Create Account</a>
                </div>
            </div>
        </div>
    </header>

    <main class="llb-public-main">
        @RenderBody()
    </main>

    <footer class="llb-public-footer py-5 mt-5">
        <div class="container-xl">
            <div class="row g-4">
                <div class="col-lg-5">
                    <h5 class="fw-bold mb-3">Liquor Licensing Board</h5>
                    <p class="text-muted mb-3">
                        A single digital workspace for liquor licence applications, renewals, inspections, post-formation services, and document access.
                    </p>
                    <div class="d-flex flex-column gap-1 text-muted">
                        <span><i class="bi bi-geo-alt me-2 text-primary"></i>Corner of Herbert Chitepo Avenue and Harare Street, Harare</span>
                        <span><i class="bi bi-telephone me-2 text-primary"></i>(024) 2792751</span>
                    </div>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-bold mb-3">Quick Links</h6>
                    <div class="d-flex flex-column gap-2">
                        <a href="/Home/LandingPage#services" class="text-decoration-none">Services</a>
                        <a href="/Home/FAQ" class="text-decoration-none">Frequently Asked Questions</a>
                        <a href="/Auth/Login" class="text-decoration-none">Sign In</a>
                        <a href="/Auth/Register" class="text-decoration-none">Register</a>
                    </div>
                </div>
                <div class="col-lg-4" id="contact">
                    <h6 class="fw-bold mb-3">Need Help?</h6>
                    <p class="text-muted mb-3">
                        Use the portal to register, submit applications, track progress, and manage post-approval services from one account.
                    </p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="/Auth/Register" class="btn btn-primary">Start Application</a>
                        <a href="/Home/FAQ" class="btn btn-outline-primary">Read FAQ</a>
                    </div>
                </div>
            </div>
            <hr class="my-4" />
            <div class="d-flex flex-column flex-md-row justify-content-between gap-2 text-muted small">
                <span>&copy; @DateTime.Now.Year Liquor Licensing Board. All rights reserved.</span>
                <span>Designed for digital licensing workflows.</span>
            </div>
        </div>
    </footer>

    <script src="~/NiceAdmin/assets/js/jquery.min.js"></script>
    <script src="~/NiceAdmin/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/countrylist.js"></script>
    <script src="~/country-master/dist/crs.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
