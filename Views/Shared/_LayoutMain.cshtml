@using System
@using Microsoft.AspNetCore.Identity
@using System.Linq
@inject UserManager<ApplicationUser> userManager

@{
    var currentUser = User?.Identity?.IsAuthenticated == true
        ? userManager.Users.FirstOrDefault(e => e.UserName == User.Identity!.Name)
        : null;
    var roles = currentUser == null ? Array.Empty<string>() : (await userManager.GetRolesAsync(currentUser)).ToArray();
    var primaryRole = roles.FirstOrDefault() ?? "workspace";
    var nameParts = new[] { currentUser?.Name, currentUser?.LastName }.Where(part => !string.IsNullOrWhiteSpace(part));
    var username = nameParts.Any() ? string.Join(" ", nameParts) : currentUser?.UserName ?? "LLB User";
    var userInitial = !string.IsNullOrWhiteSpace(username) ? username.Substring(0, 1).ToUpperInvariant() : "L";
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    var actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var pageTitle = ViewData["Title"]?.ToString();

    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = $"{controllerName} {actionName}".Trim();
    }

    var pageSubtitle = ViewData["Subtitle"]?.ToString() ?? $"Working as {primaryRole}";
}

