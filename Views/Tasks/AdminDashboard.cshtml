@{
    Layout = "_LayoutMain";
    ViewData["Title"] = "Admin Dashboard";
    ViewData["Subtitle"] = "Monitor assignment workload across verification, recommendation, approval, and follow-up work";

    var totalTasks = ViewBag.UnAssigned.Count + ViewBag.Assigned.Count + ViewBag.Completed.Count;

    Func<string?, string> statusClass = status => status?.ToLowerInvariant() switch
    {
        "assigned" => "llb-status-info",
        "reassigned" => "llb-status-warning",
        "completed" => "llb-status-success",
        "unassigned" => "llb-status-danger",
        _ => "llb-status-info"
    };
}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Unassigned</p>
                    <h3>@ViewBag.UnAssigned.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-diagram-3"></i></span>
            </div>
            <p>Tasks waiting for an owner or redistribution.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Assigned</p>
                    <h3>@ViewBag.Assigned.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-person-check"></i></span>
            </div>
            <p>Tasks actively owned by internal staff across workflow stages.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Completed</p>
                    <h3>@ViewBag.Completed.Count</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-check2-circle"></i></span>
            </div>
            <p>Tasks already cleared by the assigned internal team.</p>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card llb-stat-card">
            <div class="llb-stat-head">
                <div>
                    <p class="mb-1">Total Observed</p>
                    <h3>@totalTasks</h3>
                </div>
                <span class="llb-stat-icon"><i class="bi bi-kanban"></i></span>
            </div>
            <p>A quick operational picture of visible work items in the board workflow.</p>
        </div>
    </div>
</div>

<div class="card llb-panel-card mb-4">
    <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
        <div>
            <div class="llb-section-kicker">Operations</div>
            <h2 class="h3 fw-bold mb-2">Assignment control centre</h2>
            <p class="text-muted mb-0">
                Review current workload and reassign tasks where queues, approvals, or staff availability require intervention.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/Tasks/BulkReassignment" class="btn btn-primary">
                <i class="bi bi-shuffle me-2"></i>Bulk Reassignment
            </a>
            <a href="/Admin/RegisterUser" class="btn btn-outline-primary">
                <i class="bi bi-person-plus me-2"></i>Register User
            </a>
        </div>
    </div>
</div>

<div class="card llb-table-card">
    <div class="card-header">
        <h5 class="card-title">Assigned Task Register</h5>
    </div>
    <div class="card-body">
        @if (ViewBag.AllDetails.Count == 0)
        {
            <div class="llb-empty-state">
                <i class="bi bi-inbox"></i>
                <h5 class="fw-bold">No assigned tasks available</h5>
                <p class="text-muted mb-0">When tasks are assigned or reassigned, they will appear here for management review.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Examiner</th>
                            <th>Task Date</th>
                            <th>Licence</th>
                            <th>Stage</th>
                            <th>Service</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in ViewBag.AllDetails)
                        {
                            <tr>
                                <td class="fw-semibold">@task.RefNumber</td>
                                <td>@task.ExaminerName</td>
                                <td>@task.DateCreated.ToString("dd MMM yyyy")</td>
                                <td>@task.LicenseType</td>
                                <td>@task.JobStatus</td>
                                <td>@task.ApplicationName</td>
                                <td>
                                    <span class="llb-status-pill @statusClass(task.TaskStatus)">@task.TaskStatus</span>
                                </td>
                                <td class="text-end">
                                    <a href="/Tasks/AssignTask?Id=@task.Id" class="btn btn-sm btn-primary">Open Task</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
